---
interface Project {
  name: string;
  url?: string;
  image?: string;
  type: "personal" | "work";
  description: string;
  highlight: string;
  tech: string[];
  features: string[];
  infra?: string;
}

const projects: Project[] = [
  {
    name: "Get Content",
    url: "https://getcontent.app",
    image: "/images/projects/getcontent.png",
    type: "personal",
    description: "AI-powered marketing asset generation platform. An AI agent helps you define campaigns through chat, then a content pipeline generates images, videos with voiceovers, music, and animations — all from a single idea. The entire app was built end-to-end using AI-assisted development.",
    highlight: "Creating marketing content is expensive and slow. Get Content solves this with two layers of AI: first, an AI agent (Gemini/Claude) that you chat with to define what you want — it uses tools to generate files, follows best practices, and builds the campaign for you. Second, a content generation pipeline using Gemini for images, ElevenLabs for voiceovers, and FFmpeg to compose everything into polished videos with music.",
    tech: ["Next.js 15", "TypeScript", "tRPC", "Prisma 6", "Tailwind CSS", "Google Gemini", "Claude", "ElevenLabs", "Playwright", "FFmpeg", "Stripe", "PostgreSQL"],
    features: [
      "AI agent chat — define campaigns via conversation, agent uses tools to generate output",
      "Content pipeline — Gemini (images/text), ElevenLabs (voice), FFmpeg (video composition)",
      "From static images to full videos with voiceovers, music, and animations",
      "Admin dashboard with user management and billing",
      "Credit-based + subscription billing via Stripe",
    ],
    infra: "GCP (e2-medium, Container-Optimized OS) · Docker · Nginx · Cloudflare · Cloud SQL",
  },
  {
    name: "Refine & Learn",
    url: "https://refineandlearn.com",
    image: "/images/projects/refineandlearn.png",
    type: "personal",
    description: "AI-powered English improvement platform born from a personal need — after years of English lessons, I had no way to track my actual level, spot recurring mistakes, or measure real progress. RefineAndLearn listens to you speak, analyzes your mistakes, and gives concrete feedback.",
    highlight: "Traditional language learning gives you lessons but no real feedback loop. RefineAndLearn changes that — it listens to your speech, points out exactly where you paused or chose the wrong word, generates personalized practice exercises to target your weak spots, and tracks your progress over time.",
    tech: ["React 19", "TypeScript", "Vite 6", "Tailwind CSS", "Node.js", "Express", "Firebase", "Google Gemini", "OpenRouter", "Google Cloud Speech", "WebSocket", "FFmpeg", "Sentry"],
    features: [
      "Real-time speech analysis — detects mistakes, hesitations, and word choice issues",
      "Google Cloud Speech & TTS for voice recognition and pronunciation feedback",
      "Multi-provider AI (Gemini + OpenRouter) for intelligent feedback and exercises",
      "Personalized practice exercises generated from your weak spots",
      "Progress tracking with charts — see your level and improvement trends",
      "PWA support — installable on mobile, works offline",
    ],
    infra: "Google Cloud Run · Docker · Cloud Build CI/CD · Firebase · Playwright E2E",
  },
  {
    name: "Propeller",
    url: "https://getonpropeller.com",
    image: "/images/projects/propeller.png",
    type: "work",
    description: "Multi-tenant SaaS for yacht charter operators. Full booking lifecycle, CRM, fleet management, and customer portal in a single platform.",
    highlight: "Charter operators juggle spreadsheets, emails, and manual processes to manage fleets and bookings. Propeller replaces all of that — fleet management, bookings, payments, contracts, and CRM in a single multi-tenant SaaS.",
    tech: [".NET 8", "PostgreSQL", "Next.js 15", "Turborepo", "Stripe", "DocuSign", "Twilio", "SendGrid"],
    features: [
      "Fleet management & dynamic pricing calendars",
      "Booking lifecycle with contracts, offers, and DocuSign e-signatures",
      "Stripe + Authorize.Net payments, operator payouts",
      "CRM with omnichannel messaging (email + SMS)",
    ],
    infra: "AWS · Docker Swarm · Traefik · GitLab CI/CD · Sentry · New Relic",
  },
  {
    name: "Dokempu",
    url: "https://dokempu.cz",
    image: "/images/projects/dokempu.png",
    type: "work",
    description: "Czech campsite marketplace. Geospatial search, AI-powered pricing scraper covering 400+ campsite websites, and a comprehensive review system.",
    highlight: "Czech campers had no centralized place to find and compare campsites. Dokempu brings them onto one platform — geospatial search, reviews, and an AI pricing scraper that reduced data collection costs by 95%.",
    tech: [".NET 7", "PostgreSQL", "PostGIS", "Next.js 13", "Playwright", "OpenRouter", "Mapbox GL"],
    features: [
      "Geospatial campsite search (PostGIS + Mapbox)",
      "AI-powered pricing scraper (~400 websites, 95% cost reduction)",
      "Review & rating system with email verification",
      "\"Camp of the Year\" community voting",
    ],
    infra: "AWS · Docker Swarm · Terraform · Ansible · GitLab CI/CD · Zabbix",
  },
  {
    name: "Campiri",
    url: "https://campiri.com",
    image: "/images/projects/campiri.png",
    type: "work",
    description: "Two-sided motorhome rental marketplace operating across 7 countries with real-time messaging, multi-gateway payments, and 7 locales from a single codebase.",
    highlight: "Renting a campervan across Central Europe meant dealing with fragmented local operators. Campiri built a unified marketplace with real-time messaging, multi-gateway payments, and a booking system handling the full rental lifecycle across 2 brands.",
    tech: [".NET 6", "PostgreSQL", "SignalR", "Next.js 14", "Stripe Connect", "Comgate", "Turborepo"],
    features: [
      "Full booking lifecycle with geospatial search and availability calendar",
      "Real-time SignalR messaging between renters and operators",
      "Multi-gateway payments (Stripe Connect + Comgate), Apple/Google Pay",
      "7-locale monorepo — 2 brands, 7 languages, single codebase",
    ],
    infra: "AWS (ECR, S3, CloudFront) + GCP (GKE Kubernetes) · GitLab CI/CD",
  },
];

interface Experience {
  role: string;
  company: string;
  period: string;
  location: string;
  description: string;
}

const experience: Experience[] = [
  {
    role: ".NET Developer",
    company: "Iguana Technology",
    period: "Apr 2019 – Present",
    location: "Prague",
    description: "Architect and maintain .NET backend systems, design APIs, and optimize database architecture for enterprise client projects.",
  },
  {
    role: "Trainer",
    company: "Gopas",
    period: "Nov 2017 – Jan 2023",
    location: "Prague",
    description: "Taught professional development courses on .NET, C#, and web technologies to corporate teams.",
  },
  {
    role: "ASP.NET MVC Developer",
    company: "Designeo Creative",
    period: "Jul 2015 – Jan 2023",
    location: "Prague",
    description: "Developed web applications using ASP.NET MVC, delivering custom solutions for diverse client needs.",
  },
  {
    role: "Software Developer",
    company: "Cleverlance",
    period: "Nov 2014 – Jun 2015",
    location: "Prague",
    description: "Developed enterprise software for banking and insurance clients.",
  },
  {
    role: "ASP.NET MVC Developer",
    company: "Devis",
    period: "Feb 2013 – May 2015",
    location: "Prague",
    description: "Built web applications with ASP.NET MVC for client projects.",
  },
  {
    role: "Quality Assurance Tester",
    company: "Siemens IT Solutions",
    period: "Jan 2011 – Jun 2011",
    location: "Prague",
    description: "Tested enterprise software systems and ensured quality standards.",
  },
];

const techCategories = [
  { name: "Backend", items: ["C#", ".NET 8", "ASP.NET Core", "EF Core", "PostgreSQL", "PostGIS", "Hangfire"] },
  { name: "Frontend", items: ["TypeScript", "Next.js 15", "React 19", "Vue.js", "Tailwind CSS", "Vite"] },
  { name: "Cloud & Ops", items: ["AWS", "GCP", "Docker", "Kubernetes", "Terraform", "Ansible", "GitLab CI"] },
  { name: "Tools", items: ["Stripe", "Playwright", "SignalR", "Sentry", "Supabase", "Twilio", "DocuSign"] },
  { name: "AI", items: ["Claude Code", "Google Gemini", "OpenRouter", "ElevenLabs", "Ollama", "Whisper"] },
];

const personalProjects = projects.filter((p) => p.type === "personal");
const workProjects = projects.filter((p) => p.type === "work");
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Lukáš Kmoch | .NET Developer</title>
    <meta name="description" content="Portfolio of Lukáš Kmoch — .NET developer and tech enthusiast. Backend systems, fullstack applications, and AI-powered development." />
    <meta name="theme-color" content="#07060A" />
    <meta property="og:title" content="Lukáš Kmoch | .NET Developer" />
    <meta property="og:type" content="website" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=Syne:wght@400;500;600;700;800&family=Lora:ital,wght@0,400;0,500;0,600;1,400&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
  </head>
  <body>

    <!-- Ambient atmosphere -->
    <div class="ambient-top-right" aria-hidden="true"></div>
    <div class="ambient-bottom-left" aria-hidden="true"></div>

    <!-- NAVIGATION -->
    <header class="site-nav" id="site-nav">
      <div class="nav-inner">
        <a href="#home" class="nav-logo">LK</a>
        <nav class="nav-links">
          <a href="#about">About</a>
          <a href="#experience">Experience</a>
          <a href="#tech">Stack</a>
          <a href="#projects">Work</a>
          <a href="#personal">Projects</a>
        </nav>
        <a href="https://github.com/magiak" target="_blank" class="nav-gh">GitHub ↗</a>
      </div>
    </header>

    <!-- HERO -->
    <section id="home" class="hero">
      <div class="hero-inner">
        <div class="hero-content">
          <p class="hero-eyebrow">
            <span class="eyebrow-dot"></span>
            <span>Software Engineer &nbsp;·&nbsp; Prague, CZ</span>
          </p>
          <h1 class="hero-name">Lukáš<br />Kmoch</h1>
          <p class="hero-role">.NET Developer &amp; AI Enthusiast</p>
          <p class="hero-bio">15+ years building scalable applications. Currently using AI to build and ship robust fullstack products at unprecedented speed.</p>
          <div class="hero-cta">
            <a href="#projects" class="btn-gold">View Work</a>
            <a href="https://github.com/magiak" target="_blank" class="btn-outline">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
              GitHub
            </a>
          </div>
        </div>
        <div class="hero-visual">
          <div class="hero-photo-wrap">
            <img src="/images/lukas-hero.webp" alt="Lukáš Kmoch" width="864" height="1232" />
          </div>
        </div>
      </div>
      <div class="hero-stats">
        <div class="stat">
          <span class="stat-n">15+</span>
          <span class="stat-l">Years of Experience</span>
        </div>
        <div class="stat-divider"></div>
        <div class="stat">
          <span class="stat-n">10+</span>
          <span class="stat-l">Companies Served</span>
        </div>
        <div class="stat-divider"></div>
        <div class="stat">
          <span class="stat-n">5</span>
          <span class="stat-l">Products Shipped</span>
        </div>
      </div>
    </section>

    <!-- ABOUT -->
    <section id="about" class="page-section reveal">
      <div class="sec-head">
        <div class="sec-label">
          <span class="sec-num">01</span>
          <h2 class="sec-title">About</h2>
        </div>
        <span class="sec-ghost" aria-hidden="true">01</span>
      </div>
      <div class="about-body">
        <p>Hi, I'm Lukáš. At my core, I'm a <strong>.NET developer</strong> with a deep understanding of scalable application architecture. I've helped build the backend and frontend for 10+ companies including <em>Prazdroj, TSSK, Nakit, Lightverse, Dokempu, Campiri, Propeller, Freeway, Yacht Smart, and Skoda</em>.</p>
        <p>I have deep experience building .NET MVC apps, Razor pages, and robust APIs. My deepest expertise lies in my 15 years of backend architecture experience, but I've deliberately expanded toward the frontend—initially exploring Vue a few years ago before shifting my full focus to React. While frontend certainly isn't my main strength, I know enough to comfortably navigate modern UI code. By combining this knowledge with AI tooling, I can expertly review, verify, and orchestrate frontend generation. This allows me to confidently build and validate full-stack solutions end-to-end, without shifting focus away from my core backend strengths.</p>
        <p>I'm a tech enthusiast who loves both learning and teaching. For over 5 years, I led .NET and web development courses at <strong>Gopas</strong>, helping corporate teams level up their engineering skills. Today, I share my learnings in the open — posting regularly on LinkedIn and experimenting deeply with AI applications, Claude Code agents, custom rules, and AI skills.</p>
      </div>
    </section>

    <!-- EXPERIENCE -->
    <section id="experience" class="page-section reveal">
      <div class="sec-head">
        <div class="sec-label">
          <span class="sec-num">02</span>
          <h2 class="sec-title">Experience</h2>
        </div>
        <span class="sec-ghost" aria-hidden="true">02</span>
      </div>
      <div class="exp-table">
        {experience.map((exp, i) => (
          <div class={`exp-row ${i === 0 ? "exp-current" : ""}`}>
            <div class="exp-meta">
              <span class="exp-period">{exp.period}</span>
              <span class="exp-loc">{exp.location}</span>
            </div>
            <div class="exp-content">
              <div class="exp-header">
                <span class="exp-role">{exp.role}</span>
                <span class="exp-sep">@</span>
                <span class="exp-company">{exp.company}</span>
              </div>
              <p class="exp-desc">{exp.description}</p>
            </div>
            {i === 0 && <span class="now-badge">NOW</span>}
          </div>
        ))}
      </div>
    </section>

    <!-- EDUCATION -->
    <section id="education" class="page-section reveal">
      <div class="sec-head">
        <div class="sec-label">
          <span class="sec-num">03</span>
          <h2 class="sec-title">Education</h2>
        </div>
        <span class="sec-ghost" aria-hidden="true">03</span>
      </div>
      <div class="edu-row">
        <span class="edu-period">2012 – 2015</span>
        <div class="edu-content">
          <p class="edu-inst">Czech Technical University in Prague</p>
          <p class="edu-deg">Master's degree, Web and Software Engineering <span class="edu-title-badge">Ing.</span></p>
        </div>
      </div>
    </section>

    <!-- TECH STACK -->
    <section id="tech" class="page-section reveal">
      <div class="sec-head">
        <div class="sec-label">
          <span class="sec-num">04</span>
          <h2 class="sec-title">Core Stack</h2>
        </div>
        <span class="sec-ghost" aria-hidden="true">04</span>
      </div>
      <div class="tech-table">
        {techCategories.map((cat) => (
          <div class="tech-row">
            <span class="tech-cat">{cat.name}</span>
            <div class="tech-items">
              {cat.items.map((item) => (
                <span class="tech-pill">{item}</span>
              ))}
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- COMMERCIAL PROJECTS -->
    <section id="projects" class="page-section reveal">
      <div class="sec-head">
        <div class="sec-label">
          <span class="sec-num">05</span>
          <h2 class="sec-title">Commercial Work</h2>
        </div>
        <span class="sec-ghost" aria-hidden="true">05</span>
      </div>
      <p class="sec-sub">Enterprise products where I've architected APIs, built scalable backends, and managed complex databases alongside talented development teams.</p>
      <div class="proj-list">
        {workProjects.map((project) => (
          <article class="proj-card">
            {project.image && (
              <a href={project.url} target="_blank" class="proj-img-wrap" rel="noopener noreferrer">
                <img src={project.image} alt={`${project.name} screenshot`} loading="lazy" />
                <span class="proj-img-overlay">Visit ↗</span>
              </a>
            )}
            <div class="proj-body">
              <div class="proj-top">
                <div class="proj-title-row">
                  <h3 class="proj-name">{project.name}</h3>
                  {project.url && (
                    <a href={project.url} target="_blank" class="proj-ext" rel="noopener noreferrer">↗</a>
                  )}
                </div>
                <span class="proj-badge">Commercial</span>
              </div>
              <p class="proj-desc">{project.description}</p>
              <blockquote class="proj-highlight">{project.highlight}</blockquote>
              <ul class="proj-features">
                {project.features.map((f) => <li>{f}</li>)}
              </ul>
              <div class="proj-tech">
                {project.tech.map((t) => <code class="proj-tag">{t}</code>)}
              </div>
              {project.infra && (
                <p class="proj-infra">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 002-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/></svg>
                  {project.infra}
                </p>
              )}
            </div>
          </article>
        ))}
      </div>
    </section>

    <!-- PERSONAL PROJECTS -->
    <section id="personal" class="page-section reveal">
      <div class="sec-head">
        <div class="sec-label">
          <span class="sec-num">06</span>
          <h2 class="sec-title">Personal Initiatives</h2>
        </div>
        <span class="sec-ghost" aria-hidden="true">06</span>
      </div>
      <p class="sec-sub">Products I've brainstormed, designed, and launched entirely from scratch — handling everything end-to-end: system architecture, UI/UX, database design, cloud infrastructure, and payment integration.</p>

      <!-- SolarCharts — featured full-width -->
      <article class="proj-card proj-featured reveal">
        <a href="https://solarcharts.net" target="_blank" class="proj-img-wrap proj-img-wide" rel="noopener noreferrer">
          <img src="/images/projects/solarcharts.png" alt="SolarCharts screenshot" loading="lazy" />
          <span class="proj-img-overlay">Visit ↗</span>
        </a>
        <div class="proj-body">
          <div class="proj-top">
            <div class="proj-title-row">
              <h3 class="proj-name">Solar Charts</h3>
              <a href="https://solarcharts.net" target="_blank" class="proj-ext" rel="noopener noreferrer">↗</a>
            </div>
            <span class="proj-badge proj-badge-personal">Personal</span>
          </div>
          <p class="proj-desc">A complete solar energy monitoring ecosystem — a data-heavy .NET backend ingesting readings from multiple devices every 10 seconds, a web dashboard with 40+ charts and an AI investment advisor, and a physical ESP32 hardware display for at-a-glance monitoring.</p>
          <blockquote class="proj-highlight">Solar panel owners rely on basic manufacturer apps with limited insights. SolarCharts goes further — a robust .NET backend handles high-frequency IoT data, PostgreSQL table partitioning manages the growing dataset, and an AI advisor gives concrete investment recommendations (e.g., "would a bigger battery pay off?").</blockquote>
          <div class="solarcharts-parts">
            <div class="solarcharts-part">
              <h4 class="part-title">Web App &amp; Backend</h4>
              <ul class="proj-features">
                <li>High-frequency data ingestion (10-second intervals, multiple devices)</li>
                <li>PostgreSQL table partitioning for large time-series datasets</li>
                <li>40+ charts — production, consumption, battery, efficiency</li>
                <li>AI Investment Advisor with personalized ROI recommendations</li>
                <li>PRO subscription tier · Automated database backups</li>
              </ul>
              <div class="proj-tech">
                <code class="proj-tag">.NET</code>
                <code class="proj-tag">ASP.NET MVC</code>
                <code class="proj-tag">C#</code>
                <code class="proj-tag">EF Core</code>
                <code class="proj-tag">PostgreSQL</code>
                <code class="proj-tag">OpenRouter</code>
              </div>
            </div>
            <div class="solarcharts-part">
              <h4 class="part-title">LiveDisplay — Hardware</h4>
              <ul class="proj-features">
                <li>Real-time energy data on a physical embedded screen</li>
                <li>Connects to SolarCharts API for live data</li>
                <li>Embedded UI built with LVGL graphics library</li>
              </ul>
              <div class="proj-tech">
                <code class="proj-tag">C/C++</code>
                <code class="proj-tag">ESP-IDF</code>
                <code class="proj-tag">LVGL</code>
                <code class="proj-tag">ESP32</code>
              </div>
            </div>
          </div>
          <p class="proj-infra">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 002-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/></svg>
            Oracle Cloud (ARM VM) · Docker Compose · Nginx · PostgreSQL · Automated backups
          </p>
        </div>
      </article>

      <!-- Get Content + Refine & Learn -->
      <div class="proj-list">
        {personalProjects.map((project) => (
          <article class="proj-card reveal">
            {project.image && (
              <a href={project.url} target="_blank" class="proj-img-wrap" rel="noopener noreferrer">
                <img src={project.image} alt={`${project.name} screenshot`} loading="lazy" />
                <span class="proj-img-overlay">Visit ↗</span>
              </a>
            )}
            <div class="proj-body">
              <div class="proj-top">
                <div class="proj-title-row">
                  <h3 class="proj-name">{project.name}</h3>
                  {project.url && (
                    <a href={project.url} target="_blank" class="proj-ext" rel="noopener noreferrer">↗</a>
                  )}
                </div>
                <span class="proj-badge proj-badge-personal">Personal</span>
              </div>
              <p class="proj-desc">{project.description}</p>
              <blockquote class="proj-highlight">{project.highlight}</blockquote>
              <ul class="proj-features">
                {project.features.map((f) => <li>{f}</li>)}
              </ul>
              <div class="proj-tech">
                {project.tech.map((t) => <code class="proj-tag">{t}</code>)}
              </div>
              {project.infra && (
                <p class="proj-infra">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 002-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/></svg>
                  {project.infra}
                </p>
              )}
            </div>
          </article>
        ))}
      </div>
    </section>

    <!-- FOOTER -->
    <footer class="site-footer">
      <div class="footer-inner">
        <span class="footer-logo">LK</span>
        <p class="footer-copy">Lukáš Kmoch &copy; {new Date().getFullYear()}</p>
