---
import Base from "../layouts/Base.astro";

interface Project {
  name: string;
  url?: string;
  image?: string;
  type: "personal" | "work";
  description: string;
  highlight: string;
  tech: string[];
  features: string[];
  infra?: string;
}

const projects: Project[] = [
  {
    name: "Get Content",
    url: "https://getcontent.app",
    image: "/images/projects/getcontent.png",
    type: "personal",
    description: "AI-powered marketing asset generation platform. An AI agent helps you define campaigns through chat, then a content pipeline generates images, videos with voiceovers, music, and animations — all from a single idea. The entire app was built end-to-end using AI-assisted development, showcasing what AI-powered engineering can build today.",
    highlight: "Creating marketing content is expensive and slow.",
    tech: ["Next.js 15", "TypeScript", "tRPC", "Prisma 6", "Tailwind CSS", "Google Gemini", "Claude", "ElevenLabs", "Playwright", "FFmpeg", "Stripe", "PostgreSQL"],
    features: [
      "AI agent chat — define campaigns via conversation, agent uses tools to generate output",
      "Content pipeline — Gemini (images/text), ElevenLabs (voice), FFmpeg (video composition)",
      "From static images to full videos with voiceovers, music, and animations",
      "Admin dashboard with user management and billing",
      "Credit-based + subscription billing via Stripe",
      "Fully vibe-coded end-to-end — frontend, backend, auth, payments",
    ],
    infra: "GCP (e2-medium, Container-Optimized OS) · Docker · Nginx · Cloudflare · Cloud SQL",
  },
  {
    name: "Refine & Learn",
    url: "https://refineandlearn.com",
    image: "/images/projects/refineandlearn.png",
    type: "personal",
    description: "AI-powered English improvement platform born from a personal need — after years of English lessons, I had no way to track my actual level, spot recurring mistakes, or measure real progress. RefineAndLearn listens to you speak, analyzes your mistakes, and gives concrete feedback on what you said wrong, where you hesitated, and which words you struggled with.",
    highlight: "Traditional language learning gives you lessons but no real feedback loop.",
    tech: ["React 19", "TypeScript", "Vite 6", "Tailwind CSS", "Node.js", "Express", "Firebase", "Google Gemini", "OpenRouter", "Google Cloud Speech", "Google TTS", "WebSocket", "FFmpeg", "Sentry"],
    features: [
      "Real-time speech analysis — detects mistakes, hesitations, and word choice issues",
      "Google Cloud Speech & TTS for voice recognition and pronunciation feedback",
      "Multi-provider AI (Gemini + OpenRouter) for intelligent feedback and exercises",
      "Personalized practice exercises generated from your weak spots",
      "Progress tracking with charts — see your level and improvement trends",
      "AI chat for learning guidance — what to focus on, how to level up",
      "PWA support — installable on mobile, works offline",
      "Text refinement — transforms rough text into polished, native-level English",
    ],
    infra: "Google Cloud Run · Docker · Cloud Build CI/CD · Firebase · Playwright E2E",
  },
  {
    name: "Propeller",
    url: "https://getonpropeller.com",
    image: "/images/projects/propeller.png",
    type: "work",
    description: "SaaS for yacht charter operators. Booking lifecycle, CRM, and customer portal.",
    highlight: "Charter operators juggle spreadsheets, emails, and manual processes to manage fleets and bookings. Propeller replaces all of that with one platform — fleet management, bookings, payments, contracts, and CRM in a single multi-tenant SaaS.",
    tech: [".NET 8", "PostgreSQL", "Next.js 15", "Turborepo", "Stripe"],
    features: [
      "Fleet management & pricing calendars",
      "Booking lifecycle with offers",
    ],
    infra: "AWS · GitLab CI/CD · Sentry",
  },
  {
    name: "Dokempu",
    url: "https://dokempu.cz",
    image: "/images/projects/dokempu.png",
    type: "work",
    description: "Czech campsite marketplace. Search, browse, and review features.",
    highlight: "Czech campers had no centralized place to find and compare campsites. Dokempu brings them onto one platform with geospatial search and comprehensive reviews, making it easier than ever to discover the perfect camping spot.",
    tech: [".NET 7", "PostgreSQL", "Next.js 13", "Playwright", "OpenRouter"],
    features: [
      "Geospatial campsite search",
      "Comprehensive review system",
    ],
    infra: "AWS · GitLab CI/CD",
  },
  {
    name: "Campiri",
    url: "https://campiri.com",
    image: "/images/projects/campiri.png",
    type: "work",
    description: "Two-sided motorhome rental marketplace. Booking, payments, messaging.",
    highlight: "Renting a campervan across Central Europe meant dealing with fragmented local operators. Campiri built a unified marketplace across 7 countries with real-time messaging, multi-gateway payments, and a booking system handling the full rental lifecycle.",
    tech: [".NET 6", "PostgreSQL", "SignalR", "Next.js 14", "Stripe Connect"],
    features: [
      "Booking lifecycle with calendar",
      "Real-time SignalR messaging",
    ],
    infra: "AWS & GCP · GitLab CI/CD",
  },
];

interface Experience {
  role: string;
  company: string;
  period: string;
  location: string;
  description: string;
}

interface Education {
  institution: string;
  degree: string;
  field: string;
  period: string;
  title: string;
}

const experience: Experience[] = [
  {
    role: ".NET Developer",
    company: "Iguana Technology",
    period: "Apr 2019 – Present",
    location: "Prague",
    description: "Architect and maintain .NET backend systems, design APIs, and optimize database architecture for enterprise client projects.",
  },
  {
    role: "Trainer",
    company: "Gopas",
    period: "Nov 2017 – Jan 2023",
    location: "Prague",
    description: "Taught professional development courses on .NET, C#, and web technologies to corporate teams.",
  },
  {
    role: "ASP.NET MVC Developer",
    company: "Designeo Creative s.r.o.",
    period: "Jul 2015 – Jan 2023",
    location: "Prague",
    description: "Developed web applications using ASP.NET MVC, delivering custom solutions for diverse client needs.",
  },
  {
    role: "Software Developer",
    company: "Cleverlance",
    period: "Nov 2014 – Jun 2015",
    location: "Prague",
    description: "Developed enterprise software for banking and insurance clients.",
  },
  {
    role: "ASP.NET MVC Developer",
    company: "Devis",
    period: "Feb 2013 – May 2015",
    location: "Prague",
    description: "Built web applications with ASP.NET MVC for client projects.",
  },
  {
    role: "Quality Assurance Tester",
    company: "Siemens IT Solutions and Services",
    period: "Jan 2011 – Jun 2011",
    location: "Prague",
    description: "Tested enterprise software systems and ensured quality standards.",
  },
];

const education: Education[] = [
  {
    institution: "Czech Technical University in Prague",
    degree: "Master's degree",
    field: "Web and Software Engineering",
    period: "2012 – 2015",
    title: "Ing.",
  },
];

const techCategories = [
  { name: "Backend (.NET Core)", items: ["C#", ".NET", "ASP.NET MVC", "Razor Pages", "EF Core", "PostgreSQL", "PostGIS"] },
  { name: "Frontend", items: ["TypeScript", "Next.js", "React", "Vue.js", "Tailwind"] },
  { name: "Cloud & Ops", items: ["AWS", "GCP", "Docker", "GitLab CI"] },
  { name: "Tools", items: ["Swagger", "Postman", "DBeaver", "Comgate", "Stripe", "Supabase", "Playwright", "Google Analytics", "Sentry"] },
  { name: "AI", items: ["Claude Code", "Open Claw", "GitHub Copilot", "Google Gemini", "OpenRouter", "Ollama", "ElevenLabs", "Whisper"] },
];

const personalProjects = projects.filter((p) => p.type === "personal");
const workProjects = projects.filter((p) => p.type === "work");
---

<Base
  title="Lukáš Kmoch | Industrial Edition"
  description="Portfolio of Lukáš Kmoch — V4 Industrial / Utilitarian Edition"
>
  <!-- Google Fonts for V4 -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500;600&family=Oswald:wght@500;700&display=swap" rel="stylesheet">

  <div class="v4-blueprint-bg"></div>
  
  <div class="v4-root">
    <div class="v4-nav-bar">
      <div class="v4-nav-brand">L.KMOCH [ENG_SYS_V4]</div>
      <div class="v4-nav-links">
        <a href="#spec">SPEC.</a>
        <a href="#work">WORK.</a>
        <a href="#tech">TECH.</a>
        <a href="/">STD_V1</a>
      </div>
      <div class="v4-sys-status">
        <span class="v4-status-dot"></span> SECURE
      </div>
    </div>

    <div class="v4-hero">
      <div class="v4-hero-left">
        <div class="v4-hero-title-wrap">
          <div class="v4-measure-line"></div>
          <h1 class="v4-hero-title">LUKÁŠ<br/>KMOCH</h1>
        </div>
        <div class="v4-hero-role">SYS. ARCHITECT // .NET DEVELOPER</div>
        <p class="v4-hero-bio">
          ENGINEERING ROBUST BACKEND SYSTEMS AND FULLSTACK APPLICATIONS. 
          SHIPPING PRODUCTION-GRADE CODE AT LIGHTNING SPEED WITH ADVANCED AI INTEGRATION.
        </p>
        <div class="v4-hero-actions">
          <a href="#work" class="v4-btn v4-btn-primary">INITIATE_VIEW: WORK</a>
          <a href="https://github.com/magiak" target="_blank" class="v4-btn v4-btn-sec">ACCESS: GITHUB</a>
        </div>
      </div>
      <div class="v4-hero-right">
        <div class="v4-hero-image-frame">
          <div class="v4-frame-marks"></div>
          <img src="/images/lukas-hero.webp" alt="Lukas Kmoch" class="v4-hero-img" />
          <div class="v4-frame-overlay">
            <span>[SRC: LK_IDENT_01]</span>
            <span>[RES: HI_DEF]</span>
          </div>
        </div>
      </div>
    </div>

    <!-- Ticker line -->
    <div class="v4-ticker-tape">
      <div class="v4-ticker-track">
        <span>WARNING: HIGH VOLTAGE ENGINEERING. SYSTEM OPERATING AT MAXIMUM EFFICIENCY. MULTIPLE DATABASES CONNECTED. A.I. PROTOCOLS ACTIVE.</span>
        <span>WARNING: HIGH VOLTAGE ENGINEERING. SYSTEM OPERATING AT MAXIMUM EFFICIENCY. MULTIPLE DATABASES CONNECTED. A.I. PROTOCOLS ACTIVE.</span>
      </div>
    </div>

    <div class="v4-grid-2" id="spec">
      <div class="v4-panel">
        <div class="v4-panel-header">
          <span class="v4-panel-id">SEQ_01</span>
          <span class="v4-panel-title">OPERATIONAL SPECIFICATION</span>
        </div>
        <div class="v4-panel-body v4-about">
          <p>
            At my core, I'm a <strong>.NET developer</strong> with a deep understanding of scalable application architecture. 
            I've helped build the backend and frontend for 10+ companies including Prazdroj, TSSK, Nakit, Lightverse, Dokempu, Campiri, Propeller, Freeway, Yacht Smart, and Skoda.
          </p>
          <p>
            My deepest expertise lies in my 15 years of backend architecture experience, but I've deliberately expanded toward the frontend—initially exploring Vue a few years ago before shifting my full focus to React. While frontend certainly isn't my main strength, I know enough to comfortably navigate modern UI code. By combining this knowledge with AI tooling, I can expertly review, verify, and orchestrate frontend generation. This allows me to confidently build and validate full-stack solutions end-to-end, without shifting focus away from my core backend strengths.
          </p>
        </div>
      </div>

      <div class="v4-panel">
        <div class="v4-panel-header">
          <span class="v4-panel-id">SEQ_02</span>
          <span class="v4-panel-title">SERVICE LOG</span>
        </div>
        <div class="v4-panel-body v4-exp">
          {experience.slice(0,4).map((exp) => (
            <div class="v4-exp-row">
              <div class="v4-exp-meta">
                <span class="v4-exp-date">{exp.period}</span>
                <span class="v4-exp-company">{exp.company}</span>
              </div>
              <div class="v4-exp-details">
                <div class="v4-exp-role">{exp.role}</div>
                <div class="v4-exp-desc">{exp.description}</div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>

    <div class="v4-panel" id="work">
      <div class="v4-panel-header">
        <span class="v4-panel-id">SEQ_03</span>
        <span class="v4-panel-title">DEPLOYED ASSETS</span>
      </div>
      <div class="v4-panel-body">
        <div class="v4-work-grid">
          
          <div class="v4-work-col">
            <h3 class="v4-work-subheading">COMMERCIAL DEPLOYMENTS</h3>
            {workProjects.map((p) => (
              <div class="v4-project">
                {p.image && (
                  <div class="v4-project-img-box">
                    <img src={p.image} alt={p.name} loading="lazy" />
                  </div>
                )}
                <div class="v4-project-info">
                  <div class="v4-project-head">
                    <h4 class="v4-project-name">{p.name}</h4>
                    {p.url && <a href={p.url} target="_blank" class="v4-project-link">[EXTERNAL_LINK]</a>}
                  </div>
                  <p class="v4-project-desc">{p.description}</p>
                  <div class="v4-project-tags">
                    {p.tech.map(t => <span class="v4-tech-pip">{t}</span>)}
                  </div>
                </div>
              </div>
            ))}
          </div>

          <div class="v4-work-col">
            <h3 class="v4-work-subheading">PERSONAL DEPLOYMENTS</h3>

            <div class="v4-project v4-project-highlight">
              <div class="v4-project-img-box">
                <img src="/images/projects/solarcharts.png" alt="Solar Charts" loading="lazy" />
                <div class="v4-hw-badge">HW + SW</div>
              </div>
              <div class="v4-project-info">
                <div class="v4-project-head">
                  <h4 class="v4-project-name">Solar Charts</h4>
                  <a href="https://solarcharts.net" target="_blank" class="v4-project-link">[EXTERNAL_LINK]</a>
                </div>
                <p class="v4-project-desc">A complete solar energy monitoring ecosystem built with .NET — high-frequency IoT data ingestion from multiple devices every 10 seconds, web dashboard with 40+ charts, AI advisor, and a physical ESP32 hardware display built with C/C++.</p>
                <div class="v4-project-tags">
                  <span class="v4-tech-pip highlight">.NET</span>
                  <span class="v4-tech-pip">PostgreSQL</span>
                  <span class="v4-tech-pip">C/C++</span>
                  <span class="v4-tech-pip">ESP32</span>
                </div>
              </div>
            </div>

            {personalProjects.map((p) => (
              <div class="v4-project">
                {p.image && (
                  <div class="v4-project-img-box">
                    <img src={p.image} alt={p.name} loading="lazy" />
                  </div>
                )}
                <div class="v4-project-info">
                  <div class="v4-project-head">
                    <h4 class="v4-project-name">{p.name}</h4>
                    {p.url && <a href={p.url} target="_blank" class="v4-project-link">[EXTERNAL_LINK]</a>}
                  </div>
                  <p class="v4-project-desc">{p.description}</p>
                  <div class="v4-project-tags">
                    {p.tech.map(t => <span class="v4-tech-pip">{t}</span>)}
                  </div>
                </div>
              </div>
            ))}
          </div>
          
        </div>
      </div>
    </div>

    <div class="v4-panel" id="tech">
      <div class="v4-panel-header">
        <span class="v4-panel-id">SEQ_04</span>
        <span class="v4-panel-title">SYSTEM CAPABILITIES</span>
      </div>
      <div class="v4-panel-body">
        <div class="v4-tech-matrix">
          {techCategories.map((cat, idx) => (
            <div class="v4-tech-block">
              <div class="v4-tech-block-head">MODULE_{idx + 1}: {cat.name}</div>
              <div class="v4-tech-block-items">
                {cat.items.map(item => <span class="v4-matrix-node">{item}</span>)}
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>

    <div class="v4-footer">
      <div class="v4-footer-left">OPERATION CONCLUDED. SYSTEM SECURE.</div>
      <div class="v4-footer-right">© {new Date().getFullYear()} LUKÁŠ KMOCH // ENG_SYS_V4</div>
    </div>

  </div>
</Base>

<style is:global>
  /* V4 INDUSTRIAL DESIGN SYSTEM */
  :root {
    --v4-bg: #0a0a0a;
    --v4-text: #d1d5db; /* Concrete Gray */
    --v4-primary: #ff5500; /* Safety Orange */
    --v4-secondary: #ffcc00; /* Warning Yellow */
    --v4-grid: #1a1a1a;
    --v4-border: #333333;
    --v4-border-light: #555555;
    
    --v4-font-head: 'Oswald', sans-serif;
    --v4-font-mono: 'IBM Plex Mono', monospace;
  }

  body:has(.v4-root) {
    background-color: var(--v4-bg);
    color: var(--v4-text);
    font-family: var(--v4-font-mono);
  }

  /* BLUEPRINT BACKGROUND */
  .v4-blueprint-bg {
    position: fixed;
    top: 0; left: 0; right: 0; bottom: 0;
    z-index: 0;
    pointer-events: none;
    background-size: 50px 50px;
    background-image: 
      linear-gradient(to right, var(--v4-grid) 1px, transparent 1px),
      linear-gradient(to bottom, var(--v4-grid) 1px, transparent 1px);
  }
  
  .v4-root {
    position: relative;
    z-index: 1;
    max-width: 1400px;
    margin: 0 auto;
    padding: 2rem 5%;
  }

  /* TYPOGRAPHY OVERRIDES */
  .v4-root h1, .v4-root h2, .v4-root h3, .v4-root h4 {
    font-family: var(--v4-font-head);
    text-transform: uppercase;
    font-weight: 700;
    margin: 0;
  }

  /* NAVIGATION */
  .v4-nav-bar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    border: 2px solid var(--v4-border);
    padding: 1rem 2rem;
    margin-bottom: 4rem;
    background: rgba(10, 10, 10, 0.9);
    backdrop-filter: blur(5px);
  }

  .v4-nav-brand {
    font-family: var(--v4-font-head);
    font-size: 1.5rem;
    color: var(--v4-primary);
    letter-spacing: 1px;
  }

  .v4-nav-links {
    display: flex;
    gap: 2rem;
  }

  .v4-nav-links a {
    color: var(--v4-text);
    text-decoration: none;
    font-size: 0.9rem;
    font-weight: 600;
    letter-spacing: 1px;
    transition: color 0.1s, background-color 0.1s;
    padding: 0.2rem 0.5rem;
  }

  .v4-nav-links a:hover {
    background: var(--v4-primary);
    color: var(--v4-bg);
  }

  .v4-sys-status {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.8rem;
    color: var(--v4-secondary);
  }

  .v4-status-dot {
    width: 8px;
    height: 8px;
    background-color: var(--v4-secondary);
    border-radius: 50%;
    animation: v4-pulse 2s infinite;
  }

  @keyframes v4-pulse {
    0% { opacity: 1; box-shadow: 0 0 0 0 rgba(255, 204, 0, 0.7); }
    70% { opacity: 0.5; box-shadow: 0 0 0 5px rgba(255, 204, 0, 0); }
    100% { opacity: 1; box-shadow: 0 0 0 0 rgba(255, 204, 0, 0); }
  }

  /* HERO */
  .v4-hero {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    margin-bottom: 6rem;
    align-items: center;
  }

  .v4-hero-title-wrap {
    display: flex;
    gap: 1rem;
    margin-bottom: 2rem;
  }

  .v4-measure-line {
    width: 4px;
    background: repeating-linear-gradient(
      to bottom,
      var(--v4-primary),
      var(--v4-primary) 10px,
      transparent 10px,
      transparent 20px
    );
  }

  .v4-hero-title {
    font-size: clamp(5rem, 10vw, 8rem);
    line-height: 0.9;
    color: #fff;
    text-shadow: -2px -2px 0 var(--v4-primary), 2px 2px 0 var(--v4-secondary);
  }

  .v4-hero-role {
    font-size: 1.2rem;
    color: var(--v4-secondary);
    border: 1px solid var(--v4-secondary);
    display: inline-block;
    padding: 0.2rem 0.8rem;
    margin-bottom: 2rem;
    background: rgba(255, 204, 0, 0.05);
  }

  .v4-hero-bio {
    font-size: 1rem;
    line-height: 1.8;
    max-width: 500px;
    margin-bottom: 3rem;
  }

  .v4-hero-actions {
    display: flex;
    gap: 1rem;
  }

  .v4-btn {
    font-family: var(--v4-font-head);
    font-size: 1.1rem;
    padding: 1rem 2rem;
    text-decoration: none;
    letter-spacing: 1px;
    transition: all 0.1s;
    text-transform: uppercase;
    cursor: pointer;
  }

  .v4-btn-primary {
    background: var(--v4-primary);
    color: var(--v4-bg);
    border: 2px solid var(--v4-primary);
  }

  .v4-btn-primary:hover {
    background: #e64d00;
  }

  .v4-btn-primary:active {
    transform: translateY(2px);
  }

  .v4-btn-sec {
    background: transparent;
    color: var(--v4-text);
    border: 2px solid var(--v4-border-light);
  }

  .v4-btn-sec:hover {
    border-color: var(--v4-text);
    background: var(--v4-text);
    color: var(--v4-bg);
  }

  .v4-hero-image-frame {
    position: relative;
    padding: 1rem;
    border: 2px solid var(--v4-border);
    background: rgba(10, 10, 10, 0.8);
  }

  .v4-frame-marks {
    position: absolute;
    top: -10px; left: -10px; right: -10px; bottom: -10px;
    border: 1px dashed var(--v4-border-light);
    pointer-events: none;
  }

  .v4-frame-marks::before, .v4-frame-marks::after {
    content: '';
    position: absolute;
    width: 20px; height: 20px;
  }
  .v4-frame-marks::before {
    top: 0; left: 0;
    border-top: 2px solid var(--v4-primary);
    border-left: 2px solid var(--v4-primary);
  }
  .v4-frame-marks::after {
    bottom: 0; right: 0;
    border-bottom: 2px solid var(--v4-primary);
    border-right: 2px solid var(--v4-primary);
  }

  .v4-hero-img {
    width: 100%;
    height: auto;
    display: block;
    filter: sepia(100%) hue-rotate(330deg) saturate(300%) contrast(150%) brightness(0.7);
    transition: filter 0.3s;
  }

  .v4-hero-image-frame:hover .v4-hero-img {
    filter: none;
  }

  .v4-frame-overlay {
    position: absolute;
    bottom: 1rem;
    left: 1rem;
    right: 1rem;
    display: flex;
    justify-content: space-between;
    font-size: 0.7rem;
    color: var(--v4-primary);
    text-shadow: 1px 1px 0 #000;
  }

  /* TICKER TAPE */
  .v4-ticker-tape {
    width: 100vw;
    position: relative;
    left: 50%;
    right: 50%;
    margin-left: -50vw;
    margin-right: -50vw;
    overflow: hidden;
    background: var(--v4-secondary);
    color: var(--v4-bg);
    padding: 0.5rem 0;
    font-weight: 600;
    margin-bottom: 6rem;
    border-top: 2px solid #000;
    border-bottom: 2px solid #000;
  }

  .v4-ticker-track {
    display: flex;
    white-space: nowrap;
    animation: v4-ticker 25s linear infinite;
  }

  .v4-ticker-track span {
    padding-right: 4rem;
  }

