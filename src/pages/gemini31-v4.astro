---
import Base from "../layouts/Base.astro";

interface Project {
  name: string;
  url?: string;
  image?: string;
  type: "personal" | "work";
  description: string;
  highlight: string;
  tech: string[];
  features: string[];
  infra?: string;
}

const projects: Project[] = [
  {
    name: "Get Content",
    url: "https://getcontent.app",
    image: "/images/projects/getcontent.png",
    type: "personal",
    description: "AI-powered marketing asset generation platform. An AI agent helps you define campaigns through chat, then a content pipeline generates images, videos with voiceovers, music, and animations — all from a single idea. The entire app was built end-to-end using AI-assisted development, showcasing what AI-powered engineering can build today.",
    highlight: "Creating marketing content is expensive and slow. Get Content solves this with two layers of AI: first, an AI agent (Gemini/Claude) that you chat with to define what you want — it uses tools to generate files, follows best practices, and builds the campaign for you. Second, a content generation pipeline using Gemini for images and text, ElevenLabs for voiceovers, and FFmpeg to compose everything into polished videos with music. One idea in, weeks of content out.",
    tech: ["Next.js 15", "TypeScript", "tRPC", "Prisma 6", "Tailwind CSS", "Google Gemini", "Claude", "ElevenLabs", "Playwright", "FFmpeg", "Stripe", "PostgreSQL"],
    features: [
      "AI agent chat — define campaigns via conversation, agent uses tools to generate output",
      "Content pipeline — Gemini (images/text), ElevenLabs (voice), FFmpeg (video composition)",
      "From static images to full videos with voiceovers, music, and animations",
      "Admin dashboard with user management and billing",
      "Credit-based + subscription billing via Stripe",
      "Fully vibe-coded end-to-end — frontend, backend, auth, payments",
    ],
    infra: "GCP (e2-medium, Container-Optimized OS) · Docker · Nginx · Cloudflare · Cloud SQL",
  },
  {
    name: "Refine & Learn",
    url: "https://refineandlearn.com",
    image: "/images/projects/refineandlearn.png",
    type: "personal",
    description: "AI-powered English improvement platform born from a personal need — after years of English lessons, I had no way to track my actual level, spot recurring mistakes, or measure real progress. RefineAndLearn listens to you speak, analyzes your mistakes, and gives concrete feedback on what you said wrong, where you hesitated, and which words you struggled with.",
    highlight: "Traditional language learning gives you lessons but no real feedback loop. RefineAndLearn changes that — it listens to your speech, points out exactly where you paused or chose the wrong word, generates personalized practice exercises to target your weak spots, and tracks your progress over time. You can also discuss your learning path with AI — what to focus on next, how to reach the next level.",
    tech: ["React 19", "TypeScript", "Vite 6", "Tailwind CSS", "Node.js", "Express", "Firebase", "Google Gemini", "OpenRouter", "Google Cloud Speech", "Google TTS", "WebSocket", "FFmpeg", "Sentry"],
    features: [
      "Real-time speech analysis — detects mistakes, hesitations, and word choice issues",
      "Google Cloud Speech & TTS for voice recognition and pronunciation feedback",
      "Multi-provider AI (Gemini + OpenRouter) for intelligent feedback and exercises",
      "Personalized practice exercises generated from your weak spots",
      "Progress tracking with charts — see your level and improvement trends",
      "AI chat for learning guidance — what to focus on, how to level up",
      "PWA support — installable on mobile, works offline",
      "Text refinement — transforms rough text into polished, native-level English",
    ],
    infra: "Google Cloud Run · Docker · Cloud Build CI/CD · Firebase · Playwright E2E",
  },
  {
    name: "Propeller",
    url: "https://getonpropeller.com",
    image: "/images/projects/propeller.png",
    type: "work",
    description: "SaaS for yacht charter operators. Booking lifecycle, CRM, and customer portal.",
    highlight: "Charter operators juggle spreadsheets, emails, and manual processes to manage fleets and bookings. Propeller replaces all of that with one platform — fleet management, bookings, payments, contracts, and CRM in a single multi-tenant SaaS.",
    tech: [".NET 8", "PostgreSQL", "Next.js 15", "Turborepo", "Stripe"],
    features: [
      "Fleet management & pricing calendars",
      "Booking lifecycle with offers",
    ],
    infra: "AWS · GitLab CI/CD · Sentry",
  },
  {
    name: "Dokempu",
    url: "https://dokempu.cz",
    image: "/images/projects/dokempu.png",
    type: "work",
    description: "Czech campsite marketplace. Search, browse, and review features.",
    highlight: "Czech campers had no centralized place to find and compare campsites. Dokempu brings them onto one platform with geospatial search and comprehensive reviews, making it easier than ever to discover the perfect camping spot.",
    tech: [".NET 7", "PostgreSQL", "Next.js 13", "Playwright", "OpenRouter"],
    features: [
      "Geospatial campsite search",
      "Comprehensive review system",
    ],
    infra: "AWS · GitLab CI/CD",
  },
  {
    name: "Campiri",
    url: "https://campiri.com",
    image: "/images/projects/campiri.png",
    type: "work",
    description: "Two-sided motorhome rental marketplace. Booking, payments, messaging.",
    highlight: "Renting a campervan across Central Europe meant dealing with fragmented local operators. Campiri built a unified marketplace across 7 countries with real-time messaging, multi-gateway payments, and a booking system handling the full rental lifecycle.",
    tech: [".NET 6", "PostgreSQL", "SignalR", "Next.js 14", "Stripe Connect"],
    features: [
      "Booking lifecycle with calendar",
      "Real-time SignalR messaging",
    ],
    infra: "AWS & GCP · GitLab CI/CD",
  },
  {
    name: "Solar Charts",
    url: "https://solarcharts.net",
    image: "/images/projects/solarcharts.png",
    type: "personal",
    description: "A complete solar energy monitoring ecosystem built with .NET — high-frequency IoT data ingestion from multiple devices every 10 seconds, web dashboard with 40+ charts, AI advisor, and a physical ESP32 hardware display built with C/C++.",
    highlight: "Monitoring solar energy typically involves generic dashboards. Solar Charts provides a highly specific, personalized dashboarding experience.",
    tech: [".NET", "PostgreSQL", "C/C++", "ESP32", "IoT"],
    features: [
      "Hardware dashboard",
      "AI insights for energy",
    ],
    infra: "Custom Hardware",
  }
];

interface Experience {
  role: string;
  company: string;
  period: string;
  location: string;
  description: string;
}

const experience: Experience[] = [
  {
    role: ".NET Developer",
    company: "Iguana Technology",
    period: "Apr 2019 – Present",
    location: "Prague",
    description: "Architect and maintain .NET backend systems, design APIs, and optimize database architecture for enterprise client projects.",
  },
  {
    role: "Trainer",
    company: "Gopas",
    period: "Nov 2017 – Jan 2023",
    location: "Prague",
    description: "Taught professional development courses on .NET, C#, and web technologies to corporate teams.",
  },
  {
    role: "ASP.NET MVC Developer",
    company: "Designeo Creative s.r.o.",
    period: "Jul 2015 – Jan 2023",
    location: "Prague",
    description: "Developed web applications using ASP.NET MVC, delivering custom solutions for diverse client needs.",
  },
  {
    role: "Software Developer",
    company: "Cleverlance",
    period: "Nov 2014 – Jun 2015",
    location: "Prague",
    description: "Developed enterprise software for banking and insurance clients.",
  },
  {
    role: "ASP.NET MVC Developer",
    company: "Devis",
    period: "Feb 2013 – May 2015",
    location: "Prague",
    description: "Built web applications with ASP.NET MVC for client projects.",
  },
];

const techCategories = [
  { name: "Backend Architecture", items: ["C#", ".NET", "ASP.NET MVC", "Razor Pages", "EF Core", "PostgreSQL", "PostGIS"] },
  { name: "Frontend Engineering", items: ["TypeScript", "Next.js", "React", "Vue.js", "Tailwind"] },
  { name: "Cloud & Infrastructure", items: ["AWS", "GCP", "Docker", "GitLab CI"] },
  { name: "Development Tools", items: ["Swagger", "Postman", "DBeaver", "Comgate", "Stripe", "Supabase", "Playwright", "Google Analytics", "Sentry"] },
  { name: "AI Orchestration", items: ["Claude Code", "Open Claw", "GitHub Copilot", "Google Gemini", "OpenRouter", "Ollama", "ElevenLabs", "Whisper"] },
];

const personalProjects = projects.filter((p) => p.type === "personal");
const workProjects = projects.filter((p) => p.type === "work");
---

<Base
  title="Lukáš Kmoch | Editorial Edition"
  description="Portfolio of Lukáš Kmoch — V6 Editorial Edition"
>
  <!-- Load fonts specifically for V6 -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;0,700;1,400&family=Outfit:wght@200;300;400;500&display=swap" rel="stylesheet">


  <main class="v6-container">
    <div class="v6-grain-overlay"></div>
    
    <nav class="v6-nav">
      <div class="v6-brand">
        <span class="v6-initial">L</span>. Kmoch
      </div>
      <div class="v6-nav-links">
        <a href="#about">About</a>
        <a href="#work">Selected Work</a>
        <a href="#tech">Capabilities</a>
        <a href="/" class="v6-accent-link">Standard V1 ↗</a>
      </div>
    </nav>

    <header class="v6-hero relative">
      <div class="v6-hero-grid">
        <div class="v6-hero-text">
          <p class="v6-eyebrow">Aesthetic Level // V6</p>
          <h1 class="v6-display">Architecting <br/><span class="v6-italic">Digital</span> <br/>Elegance.</h1>
          <p class="v6-lead">
            Senior developer engineering robust backend systems and fullstack applications. 
            Shipping production-grade code with profound architecture and modern aesthetic sensibility.
          </p>
          <div class="v6-hero-meta">
            <span class="v6-location">Based in Prague</span>
            <span class="v6-separator"></span>
            <span class="v6-status">Available for Engagements</span>
          </div>
        </div>
        <div class="v6-hero-visual">
          <div class="v6-hero-image-wrapper">
             <img src="/images/lukas-hero.webp" alt="Lukáš Kmoch" class="v6-photo" />
          </div>
        </div>
      </div>
    </header>

    <div class="v6-divider"></div>

    <section id="about" class="v6-section">
      <div class="v6-section-header">
        <h2 class="v6-section-title">The Architect</h2>
        <span class="v6-section-number">01</span>
      </div>
      <div class="v6-about-layout">
        <div class="v6-about-column v6-about-main">
          <p class="v6-dropcap">A</p>
          <p class="v6-body-text">
            t my core, I'm a .NET developer with a deep understanding of scalable application architecture. I've helped build the backend and frontend for 10+ companies including Prazdroj, TSSK, Nakit, Lightverse, Dokempu, Campiri, Propeller, Freeway, Yacht Smart, and Skoda.
          </p>
          <p class="v6-body-text">
            My deepest expertise lies in my 15 years of backend architecture experience, but I've deliberately expanded toward the frontend—initially exploring Vue a few years ago before shifting my full focus to React. While frontend certainly isn't my main strength, I know enough to comfortably navigate modern UI code. By combining this knowledge with AI tooling, I can expertly review, verify, and orchestrate frontend generation. This allows me to confidently build and validate full-stack solutions end-to-end, without shifting focus away from my core backend strengths.
          </p>
          
          <blockquote class="v6-quote">
            "The intersection of brutal efficiency and elegant design is where true engineering artistry lies."
          </blockquote>
        </div>
        
        <div class="v6-about-column v6-experience-column">
          <h3 class="v6-column-title">Timeline</h3>
          <div class="v6-timeline">
            {experience.slice(0, 4).map((exp) => (
              <div class="v6-timeline-item">
                <div class="v6-timeline-date">{exp.period}</div>
                <h4 class="v6-timeline-role">{exp.role}</h4>
                <div class="v6-timeline-company">{exp.company}</div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <div class="v6-divider"></div>

    <section id="work" class="v6-section">
      <div class="v6-section-header">
        <h2 class="v6-section-title">Selected Works</h2>
        <span class="v6-section-number">02</span>
      </div>

      <div class="v6-works-container">
        <h3 class="v6-work-category-title">Commercial Engagements</h3>
        <div class="v6-works-grid">
          {workProjects.map((project) => (
             <article class="v6-work-card">
              {project.image && (
                <div class="v6-work-image">
                  <div class="v6-image-overlay"></div>
                  <img src={project.image} alt={project.name} loading="lazy" />
                </div>
              )}
              <div class="v6-work-content">
                <div class="v6-work-header">
                  <h4 class="v6-work-title">{project.name}</h4>
                  {project.url && <a href={project.url} target="_blank" class="v6-work-link">Visit Object ↗</a>}
                </div>
                <p class="v6-work-excerpt">{project.description}</p>
                <div class="v6-work-tech">
                  {project.tech.slice(0, 4).map(t => <span class="v6-tech-item">{t}</span>)}
                </div>
              </div>
             </article>
          ))}
        </div>

        <h3 class="v6-work-category-title mt-24">Personal Artifacts</h3>
        <div class="v6-works-grid">
          {personalProjects.map((project) => (
             <article class="v6-work-card">
              {project.image && (
                <div class="v6-work-image">
                  <div class="v6-image-overlay"></div>
                  <img src={project.image} alt={project.name} loading="lazy" />
                </div>
              )}
              <div class="v6-work-content">
                <div class="v6-work-header">
                  <h4 class="v6-work-title">{project.name}</h4>
                  {project.url && <a href={project.url} target="_blank" class="v6-work-link">Visit Object ↗</a>}
                </div>
                <p class="v6-work-excerpt">{project.description}</p>
                <div class="v6-work-tech">
                  {project.tech.slice(0, 4).map(t => <span class="v6-tech-item">{t}</span>)}
                </div>
              </div>
             </article>
          ))}
        </div>
      </div>
    </section>

    <div class="v6-divider"></div>

    <section id="tech" class="v6-section">
      <div class="v6-section-header">
        <h2 class="v6-section-title">Capabilities</h2>
        <span class="v6-section-number">03</span>
      </div>
      
      <div class="v6-capabilities-grid">
        {techCategories.map((cat) => (
           <div class="v6-capability-group">
              <h4 class="v6-capability-title">{cat.name}</h4>
              <ul class="v6-capability-list">
                {cat.items.map(item => (
                  <li><span class="v6-list-bullet"></span>{item}</li>
                ))}
              </ul>
           </div>
        ))}
      </div>
    </section>

    <footer class="v6-footer">
      <div class="v6-footer-content">
        <div class="v6-brand-small">L.KMOCH</div>
        <div class="v6-footer-links">
           <a href="https://github.com/magiak" target="_blank">GitHub</a>
           <a href="/">V1 Standard</a>
           <a href="/v2">V2 Brutalist</a>
        </div>
        <div class="v6-copyright">© {new Date().getFullYear()} — Built with Intent.</div>
      </div>
    </footer>
  </main>
</Base>

<style is:global>
  /* V6 EDITORIAL DESIGN SYSTEM */
  :root {
    --v6-bg: #0a0a0b;
    --v6-surface: #121214;
    --v6-text: #e8e8e3;
    --v6-text-muted: #8c8c87;
    --v6-accent: #d4af37; /* Muted Gold */
    --v6-accent-hover: #f2ce5c;
    --v6-border: #262624;
    
    --v6-font-heading: 'Cormorant Garamond', serif;
    --v6-font-body: 'Outfit', sans-serif;
  }

  body:has(.v6-container) {
    background-color: var(--v6-bg);
    color: var(--v6-text);
    font-family: var(--v6-font-body);
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
    line-height: 1.6;
  }

  /* GRAIN TEXTURE */
  .v6-grain-overlay {
    position: fixed;
    top: 0; left: 0; width: 100vw; height: 100vh;
    pointer-events: none;
    z-index: 9999;
    opacity: 0.05;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noiseFilter'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.8' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noiseFilter)'/%3E%3C/svg%3E");
  }

  .v6-container {
    max-width: 1600px;
    margin: 0 auto;
    padding: 0 4vw;
    position: relative;
    z-index: 1;
  }

  ::selection {
    background: var(--v6-accent);
    color: var(--v6-bg);
  }

  /* TYPOGRAPHY UTILS */
  h1, h2, h3, h4, h5, h6 {
    font-family: var(--v6-font-heading);
    font-weight: 300;
    line-height: 1.1;
    margin: 0;
  }

  p {
    margin: 0;
  }

  a {
    transition: color 0.3s ease, border-color 0.3s ease;
  }

  /* NAVIGATION */
  .v6-nav {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 3rem 0;
  }

  .v6-brand {
    font-family: var(--v6-font-heading);
    font-size: 1.8rem;
    font-weight: 400;
    letter-spacing: 0.05em;
    color: var(--v6-text);
  }

  .v6-initial {
    color: var(--v6-accent);
    font-style: italic;
  }

  .v6-nav-links {
    display: flex;
    gap: 3rem;
  }

  .v6-nav-links a {
    color: var(--v6-text-muted);
    text-decoration: none;
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    font-weight: 300;
  }

  .v6-nav-links a:hover {
    color: var(--v6-text);
  }

  .v6-nav-links .v6-accent-link {
    color: var(--v6-accent);
  }
  .v6-nav-links .v6-accent-link:hover {
    color: var(--v6-accent-hover);
  }

  /* HERO */
  .v6-hero {
    min-height: 85vh;
    display: flex;
    align-items: center;
    padding-bottom: 5rem;
  }

  .v6-hero-grid {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: 6rem;
    align-items: center;
    width: 100%;
  }

  .v6-eyebrow {
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--v6-accent);
    margin-bottom: 2rem;
  }

  .v6-display {
    font-size: clamp(4rem, 8vw, 8rem);
    letter-spacing: -0.02em;
    margin-bottom: 3rem;
  }

  .v6-italic {
    font-style: italic;
    color: var(--v6-accent);
    font-weight: 300;
  }

  .v6-lead {
    font-size: 1.25rem;
    font-weight: 200;
    color: var(--v6-text-muted);
    max-width: 500px;
    line-height: 1.7;
    margin-bottom: 4rem;
  }

  .v6-hero-meta {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--v6-text-muted);
  }

  .v6-separator {
    width: 4px;
    height: 4px;
    background: var(--v6-accent);
    border-radius: 50%;
  }

  .v6-hero-visual {
    position: relative;
    padding-left: 2rem;
  }

  .v6-hero-image-wrapper {
    position: relative;
    aspect-ratio: 3/4;
    overflow: hidden;
    background: var(--v6-surface);
  }

  .v6-hero-image-wrapper::after {
    content: '';
    position: absolute;
    inset: 0;
    box-shadow: inset 0 0 0 1px rgba(255,255,255,0.1);
    pointer-events: none;
  }

  .v6-photo {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: sepia(0.2) grayscale(0.8) contrast(1.1) brightness(0.9);
    transition: filter 0.8s ease, transform 1.5s ease;
  }

  .v6-hero-image-wrapper:hover .v6-photo {
    filter: sepia(0) grayscale(0.2) contrast(1) brightness(1);
    transform: scale(1.03);
  }

  /* DIVIDER */
  .v6-divider {
    width: 100%;
    height: 1px;
    background: var(--v6-border);
    margin: 0;
  }

  /* SECTIONS */
  .v6-section {
    padding: 10rem 0;
  }

  .v6-section-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 6rem;
  }

  .v6-section-title {
    font-size: 4rem;
    font-weight: 400;
    letter-spacing: -0.01em;
  }

  .v6-section-number {
    font-family: var(--v6-font-body);
    font-size: 1.25rem;
    color: var(--v6-accent);
    font-weight: 300;
  }

  /* ABOUT LAYOUT */
  .v6-about-layout {
    display: grid;
    grid-template-columns: 1.5fr 1fr;
    gap: 8rem;
  }

  .v6-about-main {
    position: relative;
  }

  .v6-dropcap {
    float: left;
    font-family: var(--v6-font-heading);
    font-size: 7rem;
    line-height: 0.8;
    margin: 0.1em 0.15em 0 0;
    color: var(--v6-text);
    font-weight: 300;
  }

  .v6-body-text {
    font-size: 1.25rem;
    font-weight: 300;
    color: var(--v6-text-muted);
    margin-bottom: 2rem;
    line-height: 1.8;
  }

  .v6-quote {
    font-family: var(--v6-font-heading);
    font-size: 2.5rem;
    line-height: 1.3;
    color: var(--v6-accent);
    font-style: italic;
    margin: 4rem 0 0 0;
    padding-left: 2rem;
    border-left: 1px solid var(--v6-border);
  }

  .v6-column-title {
    font-family: var(--v6-font-body);
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--v6-text-muted);
    margin-bottom: 3rem;
  }

  /* TIMELINE */
  .v6-timeline {
    display: flex;
    flex-direction: column;
    gap: 3rem;
    border-left: 1px solid var(--v6-border);
    padding-left: 2rem;
  }

  .v6-timeline-item {
    position: relative;
  }

  .v6-timeline-item::before {
    content: '';
    position: absolute;
    left: -2.3rem;
    top: 5px;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--v6-accent);
  }

  .v6-timeline-date {
    font-size: 0.8rem;
    color: var(--v6-accent);
    margin-bottom: 0.5rem;
  }

  .v6-timeline-role {
    font-family: var(--v6-font-heading);
    font-size: 1.75rem;
    color: var(--v6-text);
    margin-bottom: 0.25rem;
  }

  .v6-timeline-company {
    font-size: 0.95rem;
    color: var(--v6-text-muted);
    font-weight: 300;
  }

  /* WORKS */
  .mt-24 { margin-top: 8rem; }

  .v6-work-category-title {
    font-family: var(--v6-font-body);
    font-size: 0.85rem;
    text-transform: uppercase;
