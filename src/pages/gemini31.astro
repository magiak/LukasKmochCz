---
import Base from "../layouts/Base.astro";

interface Project {
  name: string;
  url?: string;
  image?: string;
  type: "personal" | "work";
  description: string;
  highlight: string;
  tech: string[];
  features: string[];
  infra?: string;
}

const projects: Project[] = [
  {
    name: "Get Content",
    url: "https://getcontent.app",
    image: "/images/projects/getcontent.png",
    type: "personal",
    description: "AI-powered marketing asset generation platform. An AI agent helps you define campaigns through chat, then a content pipeline generates images, videos with voiceovers, music, and animations - all from a single idea. The entire app was built end-to-end using AI-assisted development, showcasing what AI-powered engineering can build today.",
    highlight: "Creating marketing content is expensive and slow. Get Content solves this with two layers of AI: first, an AI agent (Gemini/Claude) that you chat with to define what you want - it uses tools to generate files, follows best practices, and builds the campaign for you. Second, a content generation pipeline using Gemini for images and text, ElevenLabs for voiceovers, and FFmpeg to compose everything into polished videos with music. One idea in, weeks of content out.",
    tech: ["Next.js 15", "TypeScript", "tRPC", "Prisma 6", "Tailwind CSS", "Google Gemini", "Claude", "ElevenLabs", "Playwright", "FFmpeg", "Stripe", "PostgreSQL"],
    features: [
      "AI agent chat - define campaigns via conversation, agent uses tools to generate output",
      "Content pipeline - Gemini (images/text), ElevenLabs (voice), FFmpeg (video composition)",
      "From static images to full videos with voiceovers, music, and animations",
      "Admin dashboard with user management and billing",
      "Credit-based + subscription billing via Stripe",
      "Fully vibe-coded end-to-end - frontend, backend, auth, payments",
    ],
    infra: "GCP (e2-medium, Container-Optimized OS) · Docker · Nginx · Cloudflare · Cloud SQL",
  },
  {
    name: "Refine & Learn",
    url: "https://refineandlearn.com",
    image: "/images/projects/refineandlearn.png",
    type: "personal",
    description: "AI-powered English improvement platform born from a personal need - after years of English lessons, I had no way to track my actual level, spot recurring mistakes, or measure real progress. RefineAndLearn listens to you speak, analyzes your mistakes, and gives concrete feedback on what you said wrong, where you hesitated, and which words you struggled with.",
    highlight: "Traditional language learning gives you lessons but no real feedback loop. RefineAndLearn changes that - it listens to your speech, points out exactly where you paused or chose the wrong word, generates personalized practice exercises to target your weak spots, and tracks your progress over time. You can also discuss your learning path with AI - what to focus on next, how to reach the next level.",
    tech: ["React 19", "TypeScript", "Vite 6", "Tailwind CSS", "Node.js", "Express", "Firebase", "Google Gemini", "OpenRouter", "Google Cloud Speech", "Google TTS", "WebSocket", "FFmpeg", "Sentry"],
    features: [
      "Real-time speech analysis - detects mistakes, hesitations, and word choice issues",
      "Google Cloud Speech & TTS for voice recognition and pronunciation feedback",
      "Multi-provider AI (Gemini + OpenRouter) for intelligent feedback and exercises",
      "Personalized practice exercises generated from your weak spots",
      "Progress tracking with charts - see your level and improvement trends",
      "AI chat for learning guidance - what to focus on, how to level up",
      "PWA support - installable on mobile, works offline",
      "Text refinement - transforms rough text into polished, native-level English",
    ],
    infra: "Google Cloud Run · Docker · Cloud Build CI/CD · Firebase · Playwright E2E",
  },
  {
    name: "Propeller",
    url: "https://getonpropeller.com",
    image: "/images/projects/propeller.png",
    type: "work",
    description: "SaaS for yacht charter operators. Booking lifecycle, CRM, and customer portal.",
    highlight: "Charter operators juggle spreadsheets, emails, and manual processes to manage fleets and bookings. Propeller replaces all of that with one platform - fleet management, bookings, payments, contracts, and CRM in a single multi-tenant SaaS.",
    tech: [".NET 8", "PostgreSQL", "Next.js 15", "Turborepo", "Stripe"],
    features: [
      "Fleet management & pricing calendars",
      "Booking lifecycle with offers",
    ],
    infra: "AWS · GitLab CI/CD · Sentry",
  },
  {
    name: "Dokempu",
    url: "https://dokempu.cz",
    image: "/images/projects/dokempu.png",
    type: "work",
    description: "Czech campsite marketplace. Search, browse, and review features.",
    highlight: "Czech campers had no centralized place to find and compare campsites. Dokempu brings them onto one platform with geospatial search and comprehensive reviews, making it easier than ever to discover the perfect camping spot.",
    tech: [".NET 7", "PostgreSQL", "Next.js 13", "Playwright", "OpenRouter"],
    features: [
      "Geospatial campsite search",
      "Comprehensive review system",
    ],
    infra: "AWS · GitLab CI/CD",
  },
  {
    name: "Campiri",
    url: "https://campiri.com",
    image: "/images/projects/campiri.png",
    type: "work",
    description: "Two-sided motorhome rental marketplace. Booking, payments, messaging.",
    highlight: "Renting a campervan across Central Europe meant dealing with fragmented local operators. Campiri built a unified marketplace across 7 countries with real-time messaging, multi-gateway payments, and a booking system handling the full rental lifecycle.",
    tech: [".NET 6", "PostgreSQL", "SignalR", "Next.js 14", "Stripe Connect"],
    features: [
      "Booking lifecycle with calendar",
      "Real-time SignalR messaging",
    ],
    infra: "AWS & GCP · GitLab CI/CD",
  },
];

interface Experience {
  role: string;
  company: string;
  period: string;
  location: string;
  description: string;
}

interface Education {
  institution: string;
  degree: string;
  field: string;
  period: string;
  title: string;
}

const experience: Experience[] = [
  {
    role: ".NET Developer",
    company: "Iguana Technology",
    period: "Apr 2019 – 2026",
    location: "Prague",
    description: "Architect and maintain .NET backend systems, design APIs, and optimize database architecture for enterprise client projects.",
  },
  {
    role: "Trainer",
    company: "Gopas",
    period: "Nov 2017 – Jan 2023",
    location: "Prague",
    description: "Taught professional development courses on .NET to corporate teams.",
  },
  {
    role: "ASP.NET MVC Developer",
    company: "Designeo Creative s.r.o.",
    period: "Jul 2015 – Jan 2023",
    location: "Prague",
    description: "Developed web applications using ASP.NET MVC, delivering custom solutions for diverse client needs.",
  },
  {
    role: "Software Developer",
    company: "Cleverlance",
    period: "Nov 2014 – Jun 2015",
    location: "Prague",
    description: "Developed enterprise software for banking and insurance clients.",
  },
  {
    role: "ASP.NET MVC Developer",
    company: "Devis",
    period: "Feb 2013 – May 2015",
    location: "Prague",
    description: "Built web applications with ASP.NET MVC for client projects.",
  },
  {
    role: "Quality Assurance Tester",
    company: "Siemens IT Solutions and Services",
    period: "Jan 2011 – Jun 2011",
    location: "Prague",
    description: "Tested enterprise software systems and ensured quality standards.",
  },
];

const education: Education[] = [
  {
    institution: "Czech Technical University in Prague",
    degree: "Master's degree",
    field: "Web and Software Engineering",
    period: "2012 – 2015",
    title: "Ing.",
  },
];

const techCategories = [
  { name: "Backend (.NET Core)", items: ["C#", ".NET", "ASP.NET MVC", "Razor Pages", "EF Core", "PostgreSQL", "PostGIS"] },
  { name: "Frontend", items: ["TypeScript", "Next.js", "React", "Vue.js", "Tailwind"] },
  { name: "Cloud & Ops", items: ["AWS", "GCP", "Docker", "GitLab CI"] },
  { name: "Tools", items: ["Swagger", "Postman", "DBeaver", "Comgate", "Stripe", "Supabase", "Playwright", "Google Analytics", "Sentry"] },
  { name: "AI", items: ["Claude Code", "Open Claw", "GitHub Copilot", "Google Gemini", "OpenRouter", "Ollama", "ElevenLabs", "Whisper"] },
];

const personalProjects = projects.filter((p) => p.type === "personal");
const workProjects = projects.filter((p) => p.type === "work");
---

<Base
  title="Lukáš Kmoch | Alternative Edition"
  description="Portfolio of Lukáš Kmoch - V2 Neobrutalist Edition"
>
  <!-- Load fonts specifically for V2 -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Space+Mono:ital,wght@0,400;0,700;1,400;1,700&family=Syne:wght@400..800&display=swap" rel="stylesheet">

  <div class="noise-overlay"></div>

  <main class="v2-container">
    <nav class="v2-nav">
      <div class="nav-brand">LUKAS_KMOCH // SYS.V2</div>
      <ul class="nav-links">
        <li><a href="#about">[ABOUT]</a></li>
        <li><a href="#projects">[WORK]</a></li>
        <li><a href="#tech">[TECH]</a></li>
        <li><a href="/">[V1_STANDARD]</a></li>
      </ul>
    </nav>

    <header class="v2-hero">
      <div class="hero-content">
        <div class="status-badge">STATUS: ONLINE // READY TO BUILD</div>
        <h1 class="glitch-text" data-text="LUKÁŠ KMOCH">LUKÁŠ KMOCH</h1>
        <h2 class="sub-heading">SOFTWARE ENGINEER <span class="accent-primary">x</span> .NET ARCHITECT </h2>
        <p class="hero-bio">
          Senior developer engineering robust backend systems and fullstack applications. 
          Shipping production-grade code at lightning speed with advanced AI integration.
        </p>
        <div class="action-buttons">
          <a href="#projects" class="v2-btn primary">EXECUTE: VIEW_WORK</a>
          <a href="https://github.com/magiak" target="_blank" class="v2-btn secondary">SOURCE: GITHUB</a>
        </div>
      </div>
      <div class="hero-visual">
         <div class="photo-container">
           <img src="/images/lukas-hero.webp" alt="Lukáš Kmoch" class="v2-photo" />
         </div>
      </div>
    </header>

    <div class="marquee-container">
      <div class="marquee">
        <span class="marquee-text">C# • .NET • REACT • POSTGRESQL • NEXT.JS • AWS • CLAUDE • GEMINI • DOCKER • TYPESCRIPT •</span>
        <span class="marquee-text">C# • .NET • REACT • POSTGRESQL • NEXT.JS • AWS • CLAUDE • GEMINI • DOCKER • TYPESCRIPT •</span>
      </div>
    </div>

    <section id="about" class="v2-section">
      <div class="section-header">
        <h3 class="section-title">01. SYS_ABOUT</h3>
      </div>
      <div class="about-grid">
        <div class="about-text v2-card">
          <p>Hi, I'm Lukáš. At my core, I'm a <strong>.NET developer</strong> with a deep understanding of scalable application architecture. I've helped build the backend and frontend for 20+ companies including Prazdroj, TSSK, Nakit, Lightverse, Dokempu, Campiri, Propeller, Freeway, Yacht Smart, and Skoda.</p>
          <p>My deepest expertise lies in my 15 years of backend architecture experience, but I've deliberately expanded toward the frontend-initially exploring Vue a few years ago before shifting my full focus to React. While frontend certainly isn't my main strength, I know enough to comfortably navigate modern UI code. By combining this knowledge with AI tooling, I can expertly review, verify, and orchestrate frontend generation. This allows me to confidently build and validate full-stack solutions end-to-end, without shifting focus away from my core backend strengths.</p>
        </div>
        <div class="experience-list">
          {experience.slice(0, 4).map((exp) => (
            <div class="exp-item v2-card">
              <div class="exp-header">
                <h4>{exp.role} <span class="accent-secondary">@ {exp.company}</span></h4>
                <div class="exp-date">{exp.period}</div>
              </div>
              <p>{exp.description}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section id="projects" class="v2-section">
      <div class="section-header">
        <h3 class="section-title">02. DEPLOYED_WORK</h3>
      </div>
      <div class="projects-grid">
        <div class="work-col">
          <div class="col-title">COMMERCIAL</div>
          {workProjects.map((project) => (
            <div class="project-card v2-card border-primary">
               {project.image && (
                <div class="project-image-wrapper">
                  <img src={project.image} alt={project.name} class="project-img" loading="lazy"/>
                </div>
               )}
               <div class="project-details">
                 <div class="project-top">
                   <h4>{project.name}</h4>
                   {project.url && <a href={project.url} target="_blank" class="v2-icon-link">↗</a>}
                 </div>
                 <p class="project-desc">{project.description}</p>
                 <div class="project-tags">
                   {project.tech.slice(0,5).map(t => <span class="v2-tag">{t}</span>)}
                 </div>
               </div>
            </div>
          ))}
        </div>

        <div class="work-col">
          <div class="col-title">PERSONAL INITIATIVES</div>
          

          <div class="project-card v2-card border-secondary">
             <div class="project-image-wrapper">
               <img src="/images/projects/solarcharts.png" alt="Solar Charts" class="project-img" loading="lazy"/>
             </div>
             <div class="project-details">
               <div class="project-top">
                 <h4>Solar Charts <span class="badge-secondary">HARDWARE + SOFWARE</span></h4>
                 <a href="https://solarcharts.net" target="_blank" class="v2-icon-link">↗</a>
               </div>
               <p class="project-desc">A complete solar energy monitoring ecosystem built with .NET - high-frequency IoT data ingestion from multiple devices every 10 seconds, web dashboard with 40+ charts, AI advisor, and a physical ESP32 hardware display built with C/C++.</p>
               <div class="project-tags">
                 <span class="v2-tag">.NET</span>
                 <span class="v2-tag">PostgreSQL</span>
                 <span class="v2-tag">C/C++</span>
                 <span class="v2-tag">ESP32</span>
               </div>
             </div>
          </div>


          {personalProjects.map((project) => (
            <div class="project-card v2-card border-secondary">
               {project.image && (
                <div class="project-image-wrapper">
                  <img src={project.image} alt={project.name} class="project-img" loading="lazy"/>
                </div>
               )}
               <div class="project-details">
                 <div class="project-top">
                   <h4>{project.name}</h4>
                   {project.url && <a href={project.url} target="_blank" class="v2-icon-link">↗</a>}
                 </div>
                 <p class="project-desc">{project.description}</p>
                 <div class="project-tags">
                   {project.tech.slice(0,5).map(t => <span class="v2-tag">{t}</span>)}
                 </div>
               </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section id="tech" class="v2-section">
      <div class="section-header">
        <h3 class="section-title">03. TECH_STACK</h3>
      </div>
      <div class="tech-grid">
         {techCategories.map((cat) => (
           <div class="v2-card tech-category">
             <h4>{cat.name}</h4>
             <div class="tag-cloud">
               {cat.items.map(item => <span class="v2-tag tech">{item}</span>)}
             </div>
           </div>
         ))}
      </div>
    </section>

    <footer class="v2-footer">
      <div class="footer-content">
        <div class="system-status">SYSTEM OFFLINE. END OF FILE.</div>
        <div class="copyright">© {new Date().getFullYear()} LUKÁŠ KMOCH</div>
      </div>
    </footer>
  </main>
</Base>

<style is:global>
  /* V2 DESIGN SYSTEM VARIABLES */
  :root {
    --v2-bg: #050505;
    --v2-text: #f0f0f0;
    --v2-muted: #888888;
    --v2-primary: #eef937; /* Neon Yellow */
    --v2-secondary: #00f0ff; /* Electric Blue */
    --v2-border: #ffffff;
    
    --font-heading: 'Syne', sans-serif;
    --font-mono: 'Space Mono', monospace;
  }

  /* Reset some body styles for V2 specific page */
  body:has(.v2-container) {
    background-color: var(--v2-bg);
    color: var(--v2-text);
    font-family: var(--font-mono);
  }

  /* NOISE OVERLAY */
  .noise-overlay {
    position: fixed;
    top: 0; left: 0; width: 100vw; height: 100vh;
    pointer-events: none;
    z-index: 9999;
    opacity: 0.04;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noiseFilter'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.65' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noiseFilter)'/%3E%3C/svg%3E");
  }

  .v2-container {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 5%;
    position: relative;
    z-index: 1;
    overflow-x: hidden;
  }

  /* TYPOGRAPHY */
  h1, h2, h3, h4, h5, .v2-btn {
    font-family: var(--font-heading);
    text-transform: uppercase;
  }

  .accent-primary { color: var(--v2-primary); }
  .accent-secondary { color: var(--v2-secondary); }

  /* NAVIGATION */
  .v2-nav {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 2rem 0;
    border-bottom: 2px solid var(--v2-border);
    margin-bottom: 4rem;
  }

  .nav-brand {
    font-family: var(--font-heading);
    font-weight: 800;
    font-size: 1.5rem;
    letter-spacing: -1px;
    color: var(--v2-primary);
  }

  .v2-nav .nav-links {
    display: flex;
    gap: 2rem;
    list-style: none;
    margin: 0; padding: 0;
  }

  .v2-nav .nav-links a {
    color: var(--v2-text);
    text-decoration: none;
    font-weight: 700;
    font-size: 1.1rem;
    transition: all 0.2s;
  }

  .v2-nav .nav-links a:hover {
    color: var(--v2-primary);
    background: var(--v2-text);
    color: var(--v2-bg);
  }

  /* HERO */
  .v2-hero {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
    min-height: 70vh;
    margin-bottom: 6rem;
  }

  .status-badge {
    display: inline-block;
    border: 1px solid var(--v2-secondary);
    color: var(--v2-secondary);
    padding: 0.25rem 0.5rem;
    font-size: 0.8rem;
    margin-bottom: 2rem;
    box-shadow: 2px 2px 0px var(--v2-secondary);
  }

  .glitch-text {
    font-size: clamp(4rem, 10vw, 8rem);
    font-weight: 800;
    line-height: 0.9;
    margin: 0 0 1rem 0;
    position: relative;
    color: var(--v2-text);
    text-shadow: 4px 4px 0px var(--v2-primary);
  }

  .sub-heading {
    font-size: clamp(1.5rem, 3vw, 2.5rem);
    font-weight: 700;
    margin-bottom: 2rem;
    border-left: 4px solid var(--v2-secondary);
    padding-left: 1rem;
  }

  .hero-bio {
    font-size: 1.2rem;
    line-height: 1.6;
    color: var(--v2-muted);
    margin-bottom: 3rem;
    max-width: 600px;
  }

  .action-buttons {
    display: flex;
    gap: 1.5rem;
  }

  .v2-btn {
    display: inline-block;
    padding: 1rem 2rem;
    font-size: 1.2rem;
    font-weight: 800;
    text-decoration: none;
    border: 2px solid var(--v2-border);
    transition: all 0.2s;
    cursor: pointer;
  }

  .v2-btn.primary {
    background: var(--v2-primary);
    color: var(--v2-bg);
    border-color: var(--v2-primary);
    box-shadow: 6px 6px 0px var(--v2-border);
  }

  .v2-btn.primary:hover {
    transform: translate(2px, 2px);
    box-shadow: 4px 4px 0px var(--v2-border);
  }

  .v2-btn.secondary {
    background: transparent;
    color: var(--v2-text);
    box-shadow: 6px 6px 0px var(--v2-secondary);
  }
  
  .v2-btn.secondary:hover {
    background: var(--v2-secondary);
    color: var(--v2-bg);
    transform: translate(2px, 2px);
    box-shadow: 4px 4px 0px var(--v2-border);
  }

  .photo-container {
    border: 4px solid var(--v2-border);
    padding: 1rem;
    box-shadow: 15px 15px 0px var(--v2-primary);
    transform: rotate(2deg);
    transition: transform 0.3s;
  }

  .photo-container:hover {
    transform: rotate(0deg);
  }

  .v2-photo {
    width: 100%;
    height: auto;
    filter: grayscale(100%) contrast(120%);
    display: block;
  }

  /* MARQUEE */
  .marquee-container {
    width: 100%;
    overflow: hidden;
    background: var(--v2-secondary);
    color: var(--v2-bg);
    padding: 1rem 0;
    margin: 4rem 0 6rem -5%;
    width: 110vw;
    border-top: 2px solid var(--v2-border);
    border-bottom: 2px solid var(--v2-border);
    transform: rotate(-1deg);
  }

  .marquee {
    display: flex;
    white-space: nowrap;
    animation: marquee 20s linear infinite;
  }

  .marquee-text {
    font-family: var(--font-heading);
    font-weight: 800;
    font-size: 1.5rem;
    padding: 0 1rem;
  }

  @keyframes marquee {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }

  /* SECTIONS */
  .v2-section {
    margin-bottom: 8rem;
  }

  .section-header {
    margin-bottom: 3rem;
    border-bottom: 4px solid var(--v2-border);
    padding-bottom: 1rem;
  }

  .section-title {
    font-size: 3rem;
    font-weight: 800;
    margin: 0;
  }

  /* CARDS */
  .v2-card {
    background: transparent;
    border: 2px solid var(--v2-border);
    padding: 2rem;
    box-shadow: 8px 8px 0px var(--v2-border);
    transition: all 0.2s;
  }
  
  .v2-card:hover {
    transform: translate(-4px, -4px);
    box-shadow: 12px 12px 0px var(--v2-border);
  }

  .border-primary:hover { box-shadow: 12px 12px 0px var(--v2-primary); border-color: var(--v2-primary); }
  .border-secondary:hover { box-shadow: 12px 12px 0px var(--v2-secondary); border-color: var(--v2-secondary); }

  /* ABOUT */
  .about-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
  }

  .about-text {
    font-size: 1.1rem;
    line-height: 1.6;
    height: fit-content;
  }

  .about-text strong {
    color: var(--v2-primary);
    font-weight: bold;
  }

  .experience-list {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .exp-item {
    padding: 1.5rem;
  }

  .exp-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 1rem;
  }

  .exp-header h4 {
    margin: 0;
    font-size: 1.2rem;
  }

  .exp-date {
    font-size: 0.9rem;
    color: var(--v2-muted);
    border: 1px solid var(--v2-muted);
    padding: 0.2rem 0.5rem;
  }

  /* PROJECTS */
  .projects-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
  }

  .work-col {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .col-title {
    font-family: var(--font-heading);
    font-size: 1.5rem;
    font-weight: 800;
    background: var(--v2-text);
    color: var(--v2-bg);
    display: inline-block;
    padding: 0.5rem 1rem;
    margin-bottom: 1rem;
    align-self: flex-start;
  }

  .project-card {
