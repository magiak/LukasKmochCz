            <div class="mag-infra">
              <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 002-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" /></svg>
              <span>Oracle Cloud (ARM VM) · Docker Compose · Nginx · PostgreSQL · Automated backups</span>
            </div>
          </div>
        </article>

        <!-- Other personal projects -->
        <div class="project-magazine personal-grid">
          {personalProjects.map((project, i) => (
            <article class="mag-card reveal" style={`--delay: ${(i + 1) * 0.12}s`}>
