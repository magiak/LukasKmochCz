---
interface Project {
  name: string;
  url?: string;
  type: "personal" | "work";
  description: string;
  highlight: string;
  tech: string[];
  features: string[];
  infra?: string;
}

const projects: Project[] = [
  {
    name: "Get Content",
    url: "https://getcontent.app",
    type: "personal",
    description: "AI-powered marketing asset generation platform. An AI agent helps you define campaigns through chat, then a content pipeline generates images, videos with voiceovers, music, and animations — all from a single idea.",
    highlight: "Creating marketing content is expensive and slow. Get Content solves this with two layers of AI: first, an AI agent (Gemini/Claude) that you chat with to define what you want — it uses tools to generate files, follows best practices, and builds the campaign for you. Second, a content generation pipeline using Gemini for images and text, ElevenLabs for voiceovers, and FFmpeg to compose everything into polished videos with music.",
    tech: ["Next.js 15", "TypeScript", "tRPC", "Prisma 6", "Tailwind CSS", "Google Gemini", "Claude", "ElevenLabs", "FFmpeg", "Stripe", "PostgreSQL"],
    features: [
      "AI agent chat — define campaigns via conversation, agent uses tools to generate output",
      "Content pipeline — Gemini (images/text), ElevenLabs (voice), FFmpeg (video composition)",
      "Credit-based + subscription billing via Stripe",
    ],
    infra: "GCP (e2-medium) · Docker · Nginx · Cloudflare · Cloud SQL",
  },
  {
    name: "Refine & Learn",
    url: "https://refineandlearn.com",
    type: "personal",
    description: "AI-powered English improvement platform. Listens to you speak, analyzes mistakes, and gives concrete feedback on what you said wrong, where you hesitated, and which words you struggled with.",
    highlight: "Traditional language learning gives you lessons but no real feedback loop. RefineAndLearn changes that — it listens to your speech, points out exactly where you paused or chose the wrong word, and generates personalized practice exercises.",
    tech: ["React 19", "TypeScript", "Vite 6", "Tailwind CSS", "Node.js", "Express", "Firebase", "Google Gemini", "OpenRouter", "Google Cloud Speech", "Google TTS", "WebSocket", "FFmpeg"],
    features: [
      "Real-time speech analysis — detects mistakes, hesitations, and word choice issues",
      "Multi-provider AI (Gemini + OpenRouter) for intelligent feedback",
      "Personalized practice exercises generated from your weak spots",
    ],
    infra: "Google Cloud Run · Docker · Cloud Build CI/CD · Firebase",
  },
  {
    name: "Propeller",
    url: "https://getonpropeller.com",
    type: "work",
    description: "SaaS for yacht charter operators. Booking lifecycle, CRM, and customer portal.",
    highlight: "Charter operators juggle spreadsheets, emails, and manual processes to manage fleets and bookings. Propeller replaces all of that with one platform.",
    tech: [".NET 8", "PostgreSQL", "Next.js 15", "Turborepo", "Stripe"],
    features: [
      "Fleet management & pricing calendars",
      "Booking lifecycle with offers",
    ],
    infra: "AWS · GitLab CI/CD · Sentry",
  },
  {
    name: "Dokempu",
    url: "https://dokempu.cz",
    type: "work",
    description: "Czech campsite marketplace. Search, browse, and review features.",
    highlight: "Czech campers had no centralized place to find and compare campsites. Dokempu brings them onto one platform with geospatial search and comprehensive reviews.",
    tech: [".NET 7", "PostgreSQL", "Next.js 13", "Playwright", "OpenRouter"],
    features: [
      "Geospatial campsite search",
      "Comprehensive review system",
    ],
    infra: "AWS · GitLab CI/CD",
  },
  {
    name: "Campiri",
    url: "https://campiri.com",
    type: "work",
    description: "Two-sided motorhome rental marketplace across 7 countries. Booking, payments, messaging.",
    highlight: "Unified marketplace across 7 countries with real-time messaging, multi-gateway payments, and a booking system handling the full rental lifecycle.",
    tech: [".NET 6", "PostgreSQL", "SignalR", "Next.js 14", "Stripe Connect"],
    features: [
      "Booking lifecycle with calendar",
      "Real-time SignalR messaging",
    ],
    infra: "AWS & GCP · GitLab CI/CD",
  },
];

interface Experience {
  role: string;
  company: string;
  period: string;
  location: string;
  description: string;
}

interface Education {
  institution: string;
  degree: string;
  field: string;
  period: string;
  title: string;
}

const experience: Experience[] = [
  {
    role: ".NET Developer",
    company: "Iguana Technology",
    period: "Apr 2019 – Present",
    location: "Prague",
    description: "Architect and maintain .NET backend systems, design APIs, and optimize database architecture for enterprise client projects.",
  },
  {
    role: "Trainer",
    company: "Gopas",
    period: "Nov 2017 – Jan 2023",
    location: "Prague",
    description: "Taught professional development courses on .NET, C#, and web technologies to corporate teams.",
  },
  {
    role: "ASP.NET MVC Developer",
    company: "Designeo Creative s.r.o.",
    period: "Jul 2015 – Jan 2023",
    location: "Prague",
    description: "Developed web applications using ASP.NET MVC, delivering custom solutions for diverse client needs.",
  },
  {
    role: "Software Developer",
    company: "Cleverlance",
    period: "Nov 2014 – Jun 2015",
    location: "Prague",
    description: "Developed enterprise software for banking and insurance clients.",
  },
  {
    role: "ASP.NET MVC Developer",
    company: "Devis",
    period: "Feb 2013 – May 2015",
    location: "Prague",
    description: "Built web applications with ASP.NET MVC for client projects.",
  },
  {
    role: "Quality Assurance Tester",
    company: "Siemens IT Solutions and Services",
    period: "Jan 2011 – Jun 2011",
    location: "Prague",
    description: "Tested enterprise software systems and ensured quality standards.",
  },
];

const education: Education[] = [
  {
    institution: "Czech Technical University in Prague",
    degree: "Master's degree",
    field: "Web and Software Engineering",
    period: "2012 – 2015",
    title: "Ing.",
  },
];

const techCategories = [
  { name: "Backend (.NET)", items: ["C#", ".NET", "ASP.NET MVC", "Razor Pages", "EF Core", "PostgreSQL", "PostGIS"] },
  { name: "Frontend", items: ["TypeScript", "Next.js", "React", "Vue.js", "Tailwind"] },
  { name: "Cloud & Ops", items: ["AWS", "GCP", "Docker", "GitLab CI"] },
  { name: "Tools", items: ["Swagger", "Postman", "DBeaver", "Comgate", "Stripe", "Supabase", "Playwright", "Sentry"] },
  { name: "AI", items: ["Claude Code", "Open Claw", "GitHub Copilot", "Google Gemini", "OpenRouter", "Ollama", "ElevenLabs"] },
];

const personalProjects = projects.filter((p) => p.type === "personal");
const workProjects = projects.filter((p) => p.type === "work");

// Solar Charts sub-projects
const solarChartsWebFeatures = [
  "High-frequency data ingestion (10-second intervals from multiple devices)",
  "PostgreSQL table partitioning for large time-series datasets",
  "40+ charts — production, consumption, battery, efficiency",
  "AI Investment Advisor — personalized recommendations with ROI numbers",
  "PRO subscription tier with automated database backups",
];
const solarChartsHwFeatures = [
  "Real-time energy data on a physical embedded screen",
  "Embedded UI built with LVGL graphics library",
];
---

<!doctype html>
<html lang="en" data-theme="light">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Lukáš Kmoch — CV</title>
    <meta name="description" content="CV of Lukáš Kmoch — Senior .NET Developer, fullstack engineer, AI builder." />
    <meta name="robots" content="noindex" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
  </head>
  <body>

    <!-- Toolbar (hidden when printing) -->
    <div class="cv-toolbar no-print">
      <a href="/" class="toolbar-back">← Back to portfolio</a>
      <div class="toolbar-actions">
        <button id="theme-toggle" class="toolbar-btn">
          <span id="theme-icon">🌙</span>
          <span id="theme-label">Dark</span>
        </button>
        <button id="pdf-export" class="toolbar-btn primary">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4" />
            <polyline points="7 10 12 15 17 10" />
            <line x1="12" y1="15" x2="12" y2="3" />
          </svg>
          Export PDF
        </button>
      </div>
    </div>

    <div class="cv-page">

      <!-- Header -->
      <header class="cv-header">
        <div class="cv-header-main">
          <h1>Lukáš Kmoch</h1>
          <p class="cv-title">Software Engineer &amp; .NET Developer</p>
        </div>
        <div class="cv-contacts">
          <a href="https://lukaskmoch.cz" target="_blank" class="contact-item">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="10" /><line x1="2" y1="12" x2="22" y2="12" />
              <path d="M12 2a15.3 15.3 0 014 10 15.3 15.3 0 01-4 10 15.3 15.3 0 01-4-10 15.3 15.3 0 014-10z" />
            </svg>
            lukaskmoch.cz
          </a>
          <a href="https://github.com/magiak" target="_blank" class="contact-item">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
            </svg>
            github.com/magiak
          </a>
          <span class="contact-item">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z" />
              <circle cx="12" cy="10" r="3" />
            </svg>
            Prague, Czech Republic
          </span>
        </div>
      </header>

      <!-- About -->
      <section class="cv-section">
        <h2 class="cv-section-title">About</h2>
        <p class="cv-about">Senior <strong>.NET developer</strong> with 15+ years of backend architecture experience. I've helped build systems for 10+ companies including <em>Prazdroj, Campiri, Dokempu, Propeller, Skoda, and Nakit</em>. Deep expertise in .NET, APIs, and PostgreSQL. I actively use AI tooling (Claude Code, Copilot, Gemini) to ship fullstack applications faster — and I build AI-powered products on the side.</p>
      </section>

      <div class="cv-divider"></div>

      <!-- Experience -->
      <section class="cv-section">
        <h2 class="cv-section-title">Experience</h2>
        <div class="exp-list">
          {experience.map((exp, index) => (
            <div class="exp-item">
              <div class="exp-left">
                <div class="exp-role">{exp.role}</div>
                <div class="exp-company">{exp.company}</div>
              </div>
              <div class="exp-right">
                <div class="exp-period">{exp.period}</div>
                <div class="exp-location">{exp.location}</div>
              </div>
              <p class="exp-desc">{exp.description}</p>
            </div>
          ))}
        </div>
      </section>

      <div class="cv-divider"></div>

      <!-- Education -->
      <section class="cv-section">
        <h2 class="cv-section-title">Education</h2>
        {education.map((edu) => (
          <div class="edu-item">
            <div class="edu-left">
              <div class="edu-institution">{edu.institution}</div>
              <div class="edu-degree">{edu.degree}, {edu.field} <span class="edu-title">{edu.title}</span></div>
            </div>
            <div class="edu-period">{edu.period}</div>
          </div>
        ))}
      </section>

      <div class="cv-divider"></div>

      <!-- Tech -->
      <section class="cv-section">
        <h2 class="cv-section-title">Core Tech Stack</h2>
        <div class="tech-grid">
          {techCategories.map((cat) => (
            <div class="tech-row">
              <span class="tech-cat-name">{cat.name}:</span>
              <span class="tech-items">{cat.items.join(", ")}</span>
            </div>
          ))}
        </div>
      </section>

      <div class="cv-divider"></div>

      <!-- Commercial Projects -->
      <section class="cv-section">
        <h2 class="cv-section-title">Commercial Projects</h2>
        <p class="cv-section-intro">Enterprise products where I've architected APIs, built scalable backends, and managed complex databases.</p>
        <div class="project-list">
          {workProjects.map((project) => (
            <div class="project-item">
              <div class="project-item-header">
                <div class="project-item-name">
                  {project.name}
                  {project.url && <a href={project.url} target="_blank" class="project-url">↗ {project.url.replace("https://", "")}</a>}
                </div>
                <span class="badge commercial">Commercial</span>
              </div>
              <p class="project-item-desc">{project.description}</p>
              <div class="project-item-highlight">{project.highlight}</div>
              <ul class="project-item-features">
                {project.features.map(f => <li>{f}</li>)}
              </ul>
              <div class="project-item-tags">
                {project.tech.map(t => <span class="tag">{t}</span>)}
              </div>
              {project.infra && (
                <div class="project-item-infra">
                  <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 002-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
                  </svg>
                  {project.infra}
                </div>
              )}
            </div>
          ))}
        </div>
      </section>

      <div class="cv-divider"></div>

      <!-- Personal Projects -->
      <section class="cv-section">
        <h2 class="cv-section-title">Personal Initiatives</h2>
        <p class="cv-section-intro">Products I've designed, built, and launched end-to-end — architecture, UI/UX, infrastructure, and payments.</p>

        <!-- Solar Charts -->
        <div class="project-item">
          <div class="project-item-header">
            <div class="project-item-name">
              Solar Charts
              <a href="https://solarcharts.net" target="_blank" class="project-url">↗ solarcharts.net</a>
            </div>
            <span class="badge personal">Personal</span>
          </div>
          <p class="project-item-desc">A complete solar energy monitoring ecosystem — a data-heavy backend ingesting readings from multiple devices every 10 seconds, a web dashboard with 40+ charts and an AI investment advisor, and a physical ESP32 hardware display.</p>
          <div class="project-item-highlight">Solar panel owners rely on basic manufacturer apps with limited insights. SolarCharts goes further — a robust .NET backend handles high-frequency IoT data with PostgreSQL table partitioning, server-side caching, and an AI advisor that gives concrete investment recommendations.</div>
          <div class="solarcharts-parts">
            <div class="solarcharts-part">
              <div class="part-label">Web App &amp; Backend</div>
              <ul class="project-item-features">
                {solarChartsWebFeatures.map(f => <li>{f}</li>)}
              </ul>
              <div class="project-item-tags">
                {[".NET", "ASP.NET MVC", "C#", "EF Core", "PostgreSQL", "OpenRouter"].map(t => <span class="tag">{t}</span>)}
              </div>
            </div>
            <div class="solarcharts-part">
              <div class="part-label">LiveDisplay (Hardware)</div>
              <ul class="project-item-features">
                {solarChartsHwFeatures.map(f => <li>{f}</li>)}
              </ul>
              <div class="project-item-tags">
                {["C/C++", "ESP-IDF", "LVGL", "ESP32"].map(t => <span class="tag">{t}</span>)}
              </div>
            </div>
          </div>
          <div class="project-item-infra">
            <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 002-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
            </svg>
            Oracle Cloud (ARM VM) · Docker Compose · Nginx · PostgreSQL · Automated backups
          </div>
        </div>

        <div class="project-list">
          {personalProjects.map((project) => (
            <div class="project-item">
              <div class="project-item-header">
                <div class="project-item-name">
                  {project.name}
                  {project.url && <a href={project.url} target="_blank" class="project-url">↗ {project.url.replace("https://", "")}</a>}
                </div>
                <span class="badge personal">Personal</span>
              </div>
              <p class="project-item-desc">{project.description}</p>
              <div class="project-item-highlight">{project.highlight}</div>
              <ul class="project-item-features">
                {project.features.map(f => <li>{f}</li>)}
              </ul>
              <div class="project-item-tags">
                {project.tech.map(t => <span class="tag">{t}</span>)}
              </div>
              {project.infra && (
                <div class="project-item-infra">
                  <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 002-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
                  </svg>
                  {project.infra}
                </div>
              )}
            </div>
          ))}
        </div>
      </section>

      <footer class="cv-footer">
        <p>Lukáš Kmoch &copy; {new Date().getFullYear()} · <a href="https://lukaskmoch.cz" target="_blank">lukaskmoch.cz</a></p>
      </footer>

    </div>

    <script is:inline>
      (function () {
        // Restore saved theme
        const saved = localStorage.getItem("cv-theme") || "light";
        document.documentElement.setAttribute("data-theme", saved);
        updateToggleUI(saved);

        document.getElementById("theme-toggle").addEventListener("click", function () {
          const current = document.documentElement.getAttribute("data-theme");
          const next = current === "dark" ? "light" : "dark";
          document.documentElement.setAttribute("data-theme", next);
          localStorage.setItem("cv-theme", next);
          updateToggleUI(next);
        });

        document.getElementById("pdf-export").addEventListener("click", function () {
          window.print();
        });

        function updateToggleUI(theme) {
          const icon = document.getElementById("theme-icon");
          const label = document.getElementById("theme-label");
          if (theme === "dark") {
            icon.textContent = "☀️";
            label.textContent = "Light";
          } else {
            icon.textContent = "🌙";
            label.textContent = "Dark";
          }
        }
      })();
    </script>

  </body>
</html>

<style is:global>
  /* =====================
     THEME VARIABLES
  ===================== */
  :root,
  [data-theme="light"] {
    --bg: #ffffff;
    --bg-surface: #f8fafc;
    --bg-subtle: #f1f5f9;
    --text: #0f172a;
    --text-muted: #475569;
    --text-faint: #94a3b8;
    --accent: #6366f1;
    --accent-secondary: #a855f7;
    --border: #e2e8f0;
    --border-accent: rgba(99, 102, 241, 0.3);
    --card-bg: #f8fafc;
    --tag-bg: #ede9fe;
    --tag-color: #5b21b6;
    --badge-commercial-bg: #f3f0ff;
    --badge-commercial-color: #7c3aed;
    --badge-commercial-border: #ddd6fe;
    --badge-personal-bg: #e0f2fe;
    --badge-personal-color: #0369a1;
    --badge-personal-border: #bae6fd;
    --highlight-bg: #f5f3ff;
    --highlight-border: #6366f1;
    --infra-color: #64748b;
    --toolbar-bg: #f8fafc;
    --toolbar-border: #e2e8f0;
    --toolbar-text: #334155;
  }

  [data-theme="dark"] {
    --bg: #030305;
    --bg-surface: #0d0d12;
    --bg-subtle: rgba(255, 255, 255, 0.03);
    --text: #f8fafc;
    --text-muted: #94a3b8;
    --text-faint: #475569;
    --accent: #6366f1;
    --accent-secondary: #a855f7;
    --border: rgba(255, 255, 255, 0.08);
    --border-accent: rgba(168, 85, 247, 0.4);
    --card-bg: rgba(255, 255, 255, 0.03);
    --tag-bg: rgba(99, 102, 241, 0.12);
    --tag-color: #a5b4fc;
    --badge-commercial-bg: rgba(168, 85, 247, 0.15);
    --badge-commercial-color: #d8b4fe;
    --badge-commercial-border: rgba(168, 85, 247, 0.3);
    --badge-personal-bg: rgba(56, 189, 248, 0.1);
    --badge-personal-color: #7dd3fc;
    --badge-personal-border: rgba(56, 189, 248, 0.2);
    --highlight-bg: rgba(99, 102, 241, 0.05);
    --highlight-border: #6366f1;
    --infra-color: #64748b;
    --toolbar-bg: rgba(3, 3, 5, 0.9);
    --toolbar-border: rgba(255, 255, 255, 0.08);
    --toolbar-text: #94a3b8;
  }

  /* =====================
     RESET & BASE
  ===================== */
  *, *::before, *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  html {
    scroll-behavior: smooth;
  }

  body {
    font-family: "Outfit", system-ui, sans-serif;
    background: var(--bg);
    color: var(--text);
    -webkit-font-smoothing: antialiased;
    transition: background 0.25s ease, color 0.25s ease;
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  /* =====================
     TOOLBAR
  ===================== */
  .cv-toolbar {
    position: sticky;
    top: 0;
    z-index: 100;
    background: var(--toolbar-bg);
    border-bottom: 1px solid var(--toolbar-border);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.6rem 2rem;
    gap: 1rem;
  }

  .toolbar-back {
    font-size: 0.85rem;
    color: var(--text-muted);
    transition: color 0.2s;
  }
  .toolbar-back:hover {
    color: var(--accent);
  }

  .toolbar-actions {
    display: flex;
    gap: 0.5rem;
    align-items: center;
  }

  .toolbar-btn {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.45rem 0.9rem;
    border-radius: 8px;
