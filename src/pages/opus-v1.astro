---
interface Project {
  name: string;
  url?: string;
  image?: string;
  type: "personal" | "work";
  description: string;
  highlight: string;
  tech: string[];
  features: string[];
  infra?: string;
}

const projects: Project[] = [
  {
    name: "Get Content",
    url: "https://getcontent.app",
    image: "/images/projects/getcontent.png",
    type: "personal",
    description: "AI-powered marketing asset generation platform. An AI agent helps you define campaigns through chat, then a content pipeline generates images, videos with voiceovers, music, and animations — all from a single idea. The entire app was built end-to-end using AI-assisted development, showcasing what AI-powered engineering can build today.",
    highlight: "Creating marketing content is expensive and slow. Get Content solves this with two layers of AI: first, an AI agent (Gemini/Claude) that you chat with to define what you want — it uses tools to generate files, follows best practices, and builds the campaign for you. Second, a content generation pipeline using Gemini for images and text, ElevenLabs for voiceovers, and FFmpeg to compose everything into polished videos with music. One idea in, weeks of content out.",
    tech: ["Next.js 15", "TypeScript", "tRPC", "Prisma 6", "Tailwind CSS", "Google Gemini", "Claude", "ElevenLabs", "Playwright", "FFmpeg", "Stripe", "PostgreSQL"],
    features: [
      "AI agent chat — define campaigns via conversation, agent uses tools to generate output",
      "Content pipeline — Gemini (images/text), ElevenLabs (voice), FFmpeg (video composition)",
      "From static images to full videos with voiceovers, music, and animations",
      "Admin dashboard with user management and billing",
      "Credit-based + subscription billing via Stripe",
      "Fully vibe-coded end-to-end — frontend, backend, auth, payments",
    ],
    infra: "GCP (e2-medium, Container-Optimized OS) · Docker · Nginx · Cloudflare · Cloud SQL",
  },
  {
    name: "Refine & Learn",
    url: "https://refineandlearn.com",
    image: "/images/projects/refineandlearn.png",
    type: "personal",
    description: "AI-powered English improvement platform born from a personal need — after years of English lessons, I had no way to track my actual level, spot recurring mistakes, or measure real progress. RefineAndLearn listens to you speak, analyzes your mistakes, and gives concrete feedback on what you said wrong, where you hesitated, and which words you struggled with.",
    highlight: "Traditional language learning gives you lessons but no real feedback loop. RefineAndLearn changes that — it listens to your speech, points out exactly where you paused or chose the wrong word, generates personalized practice exercises to target your weak spots, and tracks your progress over time. You can also discuss your learning path with AI — what to focus on next, how to reach the next level.",
    tech: ["React 19", "TypeScript", "Vite 6", "Tailwind CSS", "Node.js", "Express", "Firebase", "Google Gemini", "OpenRouter", "Google Cloud Speech", "Google TTS", "WebSocket", "FFmpeg", "Sentry"],
    features: [
      "Real-time speech analysis — detects mistakes, hesitations, and word choice issues",
      "Google Cloud Speech & TTS for voice recognition and pronunciation feedback",
      "Multi-provider AI (Gemini + OpenRouter) for intelligent feedback and exercises",
      "Personalized practice exercises generated from your weak spots",
      "Progress tracking with charts — see your level and improvement trends",
      "AI chat for learning guidance — what to focus on, how to level up",
      "PWA support — installable on mobile, works offline",
      "Text refinement — transforms rough text into polished, native-level English",
    ],
    infra: "Google Cloud Run · Docker · Cloud Build CI/CD · Firebase · Playwright E2E",
  },
  {
    name: "Propeller",
    url: "https://getonpropeller.com",
    image: "/images/projects/propeller.png",
    type: "work",
    description: "SaaS for yacht charter operators. Booking lifecycle, CRM, and customer portal.",
    highlight: "Charter operators juggle spreadsheets, emails, and manual processes to manage fleets and bookings. Propeller replaces all of that with one platform — fleet management, bookings, payments, contracts, and CRM in a single multi-tenant SaaS.",
    tech: [".NET 8", "PostgreSQL", "Next.js 15", "Turborepo", "Stripe"],
    features: [
      "Fleet management & pricing calendars",
      "Booking lifecycle with offers",
    ],
    infra: "AWS · GitLab CI/CD · Sentry",
  },
  {
    name: "Dokempu",
    url: "https://dokempu.cz",
    image: "/images/projects/dokempu.png",
    type: "work",
    description: "Czech campsite marketplace. Search, browse, and review features.",
    highlight: "Czech campers had no centralized place to find and compare campsites. Dokempu brings them onto one platform with geospatial search and comprehensive reviews, making it easier than ever to discover the perfect camping spot.",
    tech: [".NET 7", "PostgreSQL", "Next.js 13", "Playwright", "OpenRouter"],
    features: [
      "Geospatial campsite search",
      "Comprehensive review system",
    ],
    infra: "AWS · GitLab CI/CD",
  },
  {
    name: "Campiri",
    url: "https://campiri.com",
    image: "/images/projects/campiri.png",
    type: "work",
    description: "Two-sided motorhome rental marketplace. Booking, payments, messaging.",
    highlight: "Renting a campervan across Central Europe meant dealing with fragmented local operators. Campiri built a unified marketplace across 7 countries with real-time messaging, multi-gateway payments, and a booking system handling the full rental lifecycle.",
    tech: [".NET 6", "PostgreSQL", "SignalR", "Next.js 14", "Stripe Connect"],
    features: [
      "Booking lifecycle with calendar",
      "Real-time SignalR messaging",
    ],
    infra: "AWS & GCP · GitLab CI/CD",
  },
];

interface Experience {
  role: string;
  company: string;
  period: string;
  location: string;
  description: string;
}

interface Education {
  institution: string;
  degree: string;
  field: string;
  period: string;
  title: string;
}

const experience: Experience[] = [
  {
    role: ".NET Developer",
    company: "Iguana Technology",
    period: "Apr 2019 – Present",
    location: "Prague",
    description: "Architect and maintain .NET backend systems, design APIs, and optimize database architecture for enterprise client projects.",
  },
  {
    role: "Trainer",
    company: "Gopas",
    period: "Nov 2017 – Jan 2023",
    location: "Prague",
    description: "Taught professional development courses on .NET, C#, and web technologies to corporate teams.",
  },
  {
    role: "ASP.NET MVC Developer",
    company: "Designeo Creative s.r.o.",
    period: "Jul 2015 – Jan 2023",
    location: "Prague",
    description: "Developed web applications using ASP.NET MVC, delivering custom solutions for diverse client needs.",
  },
  {
    role: "Software Developer",
    company: "Cleverlance",
    period: "Nov 2014 – Jun 2015",
    location: "Prague",
    description: "Developed enterprise software for banking and insurance clients.",
  },
  {
    role: "ASP.NET MVC Developer",
    company: "Devis",
    period: "Feb 2013 – May 2015",
    location: "Prague",
    description: "Built web applications with ASP.NET MVC for client projects.",
  },
  {
    role: "Quality Assurance Tester",
    company: "Siemens IT Solutions and Services",
    period: "Jan 2011 – Jun 2011",
    location: "Prague",
    description: "Tested enterprise software systems and ensured quality standards.",
  },
];

const education: Education[] = [
  {
    institution: "Czech Technical University in Prague",
    degree: "Master's degree",
    field: "Web and Software Engineering",
    period: "2012 – 2015",
    title: "Ing.",
  },
];

const techCategories = [
  { name: "Backend (.NET Core)", items: ["C#", ".NET", "ASP.NET MVC", "Razor Pages", "EF Core", "PostgreSQL", "PostGIS"] },
  { name: "Frontend", items: ["TypeScript", "Next.js", "React", "Vue.js", "Tailwind"] },
  { name: "Cloud & Ops", items: ["AWS", "GCP", "Docker", "GitLab CI"] },
  { name: "Tools", items: ["Swagger", "Postman", "DBeaver", "Comgate", "Stripe", "Supabase", "Playwright", "Google Analytics", "Sentry"] },
  { name: "AI", items: ["Claude Code", "Open Claw", "GitHub Copilot", "Google Gemini", "OpenRouter", "Ollama", "ElevenLabs", "Whisper"] },
];

const personalProjects = projects.filter((p) => p.type === "personal");
const workProjects = projects.filter((p) => p.type === "work");
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Lukáš Kmoch | Software Engineer</title>
    <meta name="description" content="Portfolio of Lukáš Kmoch — .NET developer and tech enthusiast. Backend systems, fullstack applications, and AI-powered development." />
    <meta property="og:title" content="Lukáš Kmoch | Software Engineer" />
    <meta property="og:description" content="Portfolio of Lukáš Kmoch — .NET developer and tech enthusiast." />
    <meta property="og:type" content="website" />
    <meta name="theme-color" content="#FDFBF7" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;500;600;700;800&family=Crimson+Pro:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400&display=swap" rel="stylesheet" />
  </head>
  <body>
    <!-- Grain texture overlay -->
    <div class="grain" aria-hidden="true"></div>

    <!-- Navigation -->
    <nav class="topbar" id="topbar">
      <a href="#hero" class="topbar-logo">LK</a>
      <ul class="topbar-links">
        <li><a href="#about">About</a></li>
        <li><a href="#experience">Experience</a></li>
        <li><a href="#tech">Stack</a></li>
        <li><a href="#work">Work</a></li>
        <li><a href="#personal">Projects</a></li>
      </ul>
    </nav>

    <main>
      <!-- Hero -->
      <section class="hero" id="hero">
        <div class="hero-inner">
          <div class="hero-content">
            <div class="hero-overline anim-fade" style="--delay: 0.1s">Software Engineer · Prague</div>
            <h1 class="hero-name">
              <span class="anim-slide" style="--delay: 0.2s">Lukáš</span>
              <span class="anim-slide" style="--delay: 0.35s">Kmoch</span>
            </h1>
            <p class="hero-subtitle anim-fade" style="--delay: 0.55s">
              Senior .NET developer using AI to build and ship robust fullstack applications at lightning speed.
            </p>
            <div class="hero-cta anim-fade" style="--delay: 0.7s">
              <a href="#personal" class="btn-primary">View Projects</a>
              <a href="https://github.com/magiak" target="_blank" rel="noopener" class="btn-ghost">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
                GitHub
              </a>
            </div>
          </div>
          <div class="hero-photo anim-fade" style="--delay: 0.5s">
            <img src="/images/lukas-hero.webp" alt="Lukáš Kmoch" width="864" height="1232" />
          </div>
        </div>
        <div class="hero-scroll anim-fade" style="--delay: 1.2s">
          <span>Scroll</span>
          <div class="scroll-line"></div>
        </div>
      </section>

      <!-- About -->
      <section class="section" id="about">
        <div class="section-header reveal">
          <span class="section-num">01</span>
          <div class="section-rule"></div>
          <h2 class="section-title">About</h2>
        </div>
        <div class="about-grid">
          <blockquote class="about-quote reveal">
            "I combine 15 years of backend architecture with modern AI tools — I'm able to build almost anything."
          </blockquote>
          <div class="about-text reveal">
            <p>Hi, I'm Lukáš. At my core, I'm a <strong>.NET developer</strong> with a deep understanding of scalable application architecture. I've helped build the backend and frontend for 10+ companies including <em>Prazdroj, TSSK, Nakit, Lightverse, Dokempu, Campiri, Propeller, Freeway, Yacht Smart, and Skoda</em>.</p>
            <p>I have deep experience building .NET MVC apps, Razor pages, and robust APIs. My deepest expertise lies in my 15 years of backend architecture experience, but I've deliberately expanded toward the frontend—initially exploring Vue a few years ago before shifting my full focus to React. While frontend certainly isn't my main strength, I know enough to comfortably navigate modern UI code. By combining this knowledge with AI tooling, I can expertly review, verify, and orchestrate frontend generation. This allows me to confidently build and validate full-stack solutions end-to-end, without shifting focus away from my core backend strengths.</p>
            <p>I'm a tech enthusiast who loves both learning and teaching. For over 5 years, I led .NET and web development courses at <strong>Gopas</strong>, helping corporate teams level up their engineering skills. Today, I share my learnings entirely in the open — posting regularly on LinkedIn and experimenting deeply with AI applications, Claude Code agents, custom rules, and AI skills.</p>
          </div>
        </div>
      </section>

      <!-- Experience -->
      <section class="section" id="experience">
        <div class="section-header reveal">
          <span class="section-num">02</span>
          <div class="section-rule"></div>
          <h2 class="section-title">Experience</h2>
        </div>
        <div class="exp-list">
          {experience.map((exp, i) => (
            <div class={`exp-row reveal ${i === 0 ? 'exp-current' : ''}`} style={`--delay: ${i * 0.08}s`}>
              <div class="exp-left">
                <h3 class="exp-role">{exp.role}</h3>
                <span class="exp-company">{exp.company}</span>
              </div>
              <div class="exp-right">
                <span class="exp-period">{exp.period}</span>
                <span class="exp-location">{exp.location}</span>
              </div>
              <p class="exp-desc">{exp.description}</p>
            </div>
          ))}
        </div>

        <!-- Education inline -->
        <div class="edu-block reveal">
          {education.map((edu) => (
            <div class="edu-row">
              <div class="edu-icon">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 10v6M2 10l10-5 10 5-10 5z" /><path d="M6 12v5c0 1.1 2.7 3 6 3s6-1.9 6-3v-5" /></svg>
              </div>
              <div>
                <strong>{edu.institution}</strong>
                <span class="edu-detail">{edu.degree}, {edu.field} <span class="edu-title">{edu.title}</span></span>
                <span class="edu-period">{edu.period}</span>
              </div>
            </div>
          ))}
        </div>
      </section>

      <!-- Tech -->
      <section class="section" id="tech">
        <div class="section-header reveal">
          <span class="section-num">03</span>
          <div class="section-rule"></div>
          <h2 class="section-title">Core Arsenal</h2>
        </div>
        <div class="tech-columns">
          {techCategories.map((cat, i) => (
            <div class="tech-col reveal" style={`--delay: ${i * 0.1}s`}>
              <h4 class="tech-label">{cat.name}</h4>
              <div class="tech-flow">
                {cat.items.map((item) => (
                  <span class="chip">{item}</span>
                ))}
              </div>
            </div>
          ))}
        </div>
      </section>

      <!-- Commercial Projects -->
      <section class="section" id="work">
        <div class="section-header reveal">
          <span class="section-num">04</span>
          <div class="section-rule"></div>
          <h2 class="section-title">Commercial Projects</h2>
        </div>
        <p class="section-lead reveal">Enterprise products where I've architected APIs, built scalable backends, and managed complex databases alongside talented development teams.</p>
        <div class="work-grid">
          {workProjects.map((project, i) => (
            <article class="work-card reveal" style={`--delay: ${i * 0.1}s`}>
              {project.image && (
                <a href={project.url} target="_blank" rel="noopener" class="work-card-img">
                  <img src={project.image} alt={`${project.name}`} loading="lazy" />
                </a>
              )}
              <div class="work-card-body">
                <div class="work-card-top">
                  <h3>
                    {project.name}
                    {project.url && <a href={project.url} target="_blank" rel="noopener" class="arrow-link">&nearr;</a>}
                  </h3>
                  <span class="label">Commercial</span>
                </div>
                <p class="work-card-desc">{project.description}</p>
                <div class="work-card-highlight">{project.highlight}</div>
                <ul class="feat-list">
                  {project.features.map(f => <li>{f}</li>)}
                </ul>
                <div class="tag-row">
                  {project.tech.map(t => <span class="tag">{t}</span>)}
                </div>
                {project.infra && (
                  <div class="infra-line">
                    <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" /></svg>
                    <span>{project.infra}</span>
                  </div>
                )}
              </div>
            </article>
          ))}
        </div>
      </section>

      <!-- Personal Projects -->
      <section class="section" id="personal">
        <div class="section-header reveal">
          <span class="section-num">05</span>
          <div class="section-rule"></div>
          <h2 class="section-title">Personal Initiatives</h2>
        </div>
        <p class="section-lead reveal">Products I've brainstormed, designed, and launched entirely from scratch — system architecture, UI/UX, database design, cloud infrastructure, and payment integration.</p>

        <!-- Solar Charts featured -->
        <article class="featured-project reveal">
          <div class="featured-img">
            <a href="https://solarcharts.net" target="_blank" rel="noopener">
              <img src="/images/projects/solarcharts.png" alt="SolarCharts" loading="lazy" />
            </a>
          </div>
          <div class="featured-body">
            <div class="work-card-top">
              <h3>
                Solar Charts
                <a href="https://solarcharts.net" target="_blank" rel="noopener" class="arrow-link">&nearr;</a>
              </h3>
              <span class="label label-personal">Personal</span>
            </div>
            <p class="work-card-desc">A complete solar energy monitoring ecosystem built with .NET — a data-heavy backend ingesting readings from multiple devices every 10 seconds, a web dashboard with 40+ charts and an AI investment advisor, and a physical ESP32 hardware display for at-a-glance monitoring.</p>
            <div class="work-card-highlight">Solar panel owners rely on basic manufacturer apps with limited insights. SolarCharts goes further — a robust .NET backend handles high-frequency IoT data from multiple devices, with PostgreSQL table partitioning to manage the growing dataset, server-side caching for fast dashboard rendering, automated database backups, and an AI advisor that gives concrete investment recommendations. The hardware display brings the data into your home without needing a phone.</div>
            <div class="featured-parts">
              <div class="featured-part">
                <h5>Web App & Backend</h5>
                <ul class="feat-list">
                  <li>High-frequency data ingestion (10-second intervals from multiple devices)</li>
                  <li>PostgreSQL table partitioning for large time-series datasets</li>
                  <li>Server-side caching for fast dashboard rendering</li>
                  <li>40+ charts — production, consumption, battery, efficiency</li>
                  <li>AI Investment Advisor — personalized recommendations with ROI numbers</li>
                  <li>PRO subscription tier for AI features</li>
                  <li>Automated database backups</li>
                </ul>
                <div class="tag-row">
                  <span class="tag">.NET</span>
                  <span class="tag">ASP.NET MVC</span>
                  <span class="tag">C#</span>
                  <span class="tag">EF Core</span>
                  <span class="tag">PostgreSQL</span>
                  <span class="tag">OpenRouter</span>
                </div>
              </div>
              <div class="featured-part">
                <h5>LiveDisplay (Hardware)</h5>
                <ul class="feat-list">
                  <li>Real-time energy data on a physical embedded screen</li>
                  <li>Connects to SolarCharts API for live data</li>
                  <li>Embedded UI built with LVGL graphics library</li>
                </ul>
                <div class="tag-row">
                  <span class="tag">C/C++</span>
                  <span class="tag">ESP-IDF</span>
                  <span class="tag">LVGL</span>
                  <span class="tag">ESP32</span>
                </div>
              </div>
            </div>
            <div class="infra-line">
              <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" /></svg>
              <span>Oracle Cloud (ARM VM) · Docker Compose · Nginx · PostgreSQL · Automated backups</span>
            </div>
          </div>
        </article>

        <!-- Other personal projects -->
        {personalProjects.map((project, i) => (
          <article class={`featured-project ${i % 2 !== 0 ? 'featured-reverse' : ''} reveal`} style={`--delay: ${(i + 1) * 0.1}s`}>
            {project.image && (
              <div class="featured-img">
                <a href={project.url} target="_blank" rel="noopener">
                  <img src={project.image} alt={project.name} loading="lazy" />
                </a>
              </div>
            )}
            <div class="featured-body">
              <div class="work-card-top">
                <h3>
                  {project.name}
                  {project.url && <a href={project.url} target="_blank" rel="noopener" class="arrow-link">&nearr;</a>}
                </h3>
                <span class="label label-personal">Personal</span>
              </div>
              <p class="work-card-desc">{project.description}</p>
              <div class="work-card-highlight">{project.highlight}</div>
              <ul class="feat-list">
                {project.features.map(f => <li>{f}</li>)}
              </ul>
              <div class="tag-row">
                {project.tech.map(t => <span class="tag">{t}</span>)}
              </div>
              {project.infra && (
                <div class="infra-line">
                  <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" /></svg>
                  <span>{project.infra}</span>
                </div>
              )}
            </div>
          </article>
        ))}
      </section>
    </main>

    <footer class="site-footer">
      <p>Lukáš Kmoch &copy; {new Date().getFullYear()}</p>
    </footer>

    <script is:inline>
      document.addEventListener('DOMContentLoaded', () => {
        // Scroll reveal
        const observer = new IntersectionObserver((entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('visible');
              observer.unobserve(entry.target);
            }
          });
        }, { threshold: 0.08, rootMargin: '0px 0px -40px 0px' });

        document.querySelectorAll('.reveal').forEach((el) => observer.observe(el));

        // Hero animations trigger on load
        document.querySelectorAll('.anim-fade, .anim-slide').forEach((el) => {
          el.classList.add('anim-ready');
          setTimeout(() => el.classList.add('anim-go'), 100);
        });

        // Nav active state
        const sections = document.querySelectorAll('section[id]');
        const links = document.querySelectorAll('.topbar-links a');
        const navObserver = new IntersectionObserver((entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              const id = entry.target.id;
              links.forEach((a) => {
                a.classList.toggle('active', a.getAttribute('href') === '#' + id);
              });
            }
          });
        }, { rootMargin: '-20% 0px -70% 0px' });
        sections.forEach((s) => navObserver.observe(s));

        // Compact nav on scroll
        const topbar = document.getElementById('topbar');
        window.addEventListener('scroll', () => {
          topbar.classList.toggle('scrolled', window.scrollY > 80);
        }, { passive: true });
      });
    </script>
